// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//
// ---------- ENUMS ----------
//
enum UserRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
}

enum BusinessType {
  RETAIL
  RESTAURANT
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  DRAFT // New: For orders being built on the POS
  PENDING // Order created but not processed
  SENT_TO_KITCHEN // Order sent to kitchen/bar
  READY // Ready for pickup/serve
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
  VOUCHER
  ONLINE
}

enum ModifierType {
  SINGLE
  MULTIPLE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum AdjustmentType {
  ADD
  REMOVE
  SET
}

//
// ---------- TENANT (Multi-Tenancy Root) ----------
//
model Tenant {
  id           String       @id @default(cuid())
  name         String
  businessType BusinessType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users          User[]
  branches       Branch[]
  products       Product[]
  inventory      Inventory[] // Inventory records still belong to the Tenant scope
  orders         Order[]
  tables         Table[]
  modifierGroups ModifierGroup[]
  recipes        Recipe[]
  devices        POSDevice[]
  customers      Customer[]
  shifts         Shift[]
  taxes          Tax[]
  transfers      Transfer[]

  settings         Json? // feature flags, tax rates, etc.
  modifiers        Modifier[]
  categories       Category[]
  currencies       Currency[]
  stockAdjustments StockAdjustment[]
}

model Currency {
  code         String   @id // e.g., USD, EUR, LBP
  name         String // "United States Dollar"
  symbol       String? // "$"
  exchangeRate Decimal? @db.Decimal(10, 2) // Optional: relative to base currency (usually USD)
  isActive     Boolean  @default(true)

  tenants  Tenant[]
  payments Payment[]
}

//
// ---------- USERS & AUTH ----------
//
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  orders   Order[]
  shifts   Shift[]

  transfersRequested Transfer[]        @relation("TransferRequests")
  transfersApproved  Transfer[]        @relation("TransferApprovals")
  stockAdjustments   StockAdjustment[] @relation("StockAdjustments")
}

//
// ---------- BRANCHES (Physical Locations) ----------
//
model Branch {
  id        String  @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isDeleted Boolean @default(false) // Soft delete

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  tables    Table[]
  devices   POSDevice[]
  inventory Inventory[] // Inventory is tracked at the Branch level
  orders    Order[]
  shifts    Shift[]

  transfersFrom    Transfer[]        @relation("TransfersFrom")
  transfersTo      Transfer[]        @relation("TransfersTo")
  stockAdjustments StockAdjustment[]
}

//
// ---------- POS DEVICES (For Sync & Auth) ----------
//
model POSDevice {
  id       String    @id @default(cuid())
  tenantId String
  branchId String
  name     String
  token    String    @unique // device authentication token
  lastSync DateTime?
  isActive Boolean   @default(true)
  isKDS    Boolean   @default(false) // New: Flag to identify Kitchen Display Systems

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch  @relation(fields: [branchId], references: [id])
  orders Order[]
  shifts Shift[]
}

//
// ---------- PRODUCTS & INGREDIENTS ----------
//
model Category {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  code        String? @unique
  description String?
  isDeleted   Boolean @default(false)

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id          String  @id @default(cuid())
  categoryId  String
  name        String
  description String?
  isDeleted   Boolean @default(false)

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  imageUrl      String?
  sku           String?  @unique
  barcode       String?  @unique // retail
  price         Decimal? @default(0) @db.Decimal(10, 2)
  cost          Decimal? @default(0) @db.Decimal(10, 2)
  categoryId    String?
  subcategoryId String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false) // Soft delete
  isIngredient  Boolean  @default(false) // New: Differentiates raw ingredients from sellable items
  isModifiable  Boolean  @default(false) // restaurant
  createdAt     DateTime @default(now())

  taxId String?
  tax   Tax?    @relation(fields: [taxId], references: [id])

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  inventory        Inventory[]
  modifiers        Modifier[]
  recipesUsedIn    Recipe[]          @relation("SellableRecipe") // Recipe output product
  ingredientIn     Recipe[]          @relation("IngredientRecipe") // Product used as ingredient
  orderItems       OrderItem[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  subcategory      Subcategory?      @relation(fields: [subcategoryId], references: [id])
  refunds          Refund[]
  offerGroupItems  OfferGroupItem[]
  transferItems    TransferItem[]
  stockAdjustments StockAdjustment[]
}

// 
// ---------- OFFERS & DISCOUNTS (Future Enhancement) ----------
model Offer {
  id        String  @id @default(cuid())
  name      String
  basePrice Decimal @default(0) @db.Decimal(10, 2)

  offerGroups OfferGroup[]
}

model OfferGroup {
  id             String @id @default(cuid())
  offerId        String
  name           String
  freeItemsCount Int    @default(0)

  offer           Offer            @relation(fields: [offerId], references: [id])
  offerGroupItems OfferGroupItem[]
}

model OfferGroupItem {
  id           String  @id @default(cuid())
  offerGroupId String
  productId    String
  extraPrice   Decimal @default(0) @db.Decimal(10, 2)

  offerGroup OfferGroup @relation(fields: [offerGroupId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

//
// ---------- INVENTORY (Branch-Scoped) ----------
//
model Inventory {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String // FIXED: Link to Branch
  productId    String
  stock        Decimal  @default(0) @db.Decimal(10, 4)
  minStock     Decimal  @default(0) @db.Decimal(10, 4) // Minimum stock threshold for low stock alerts
  lastAdjusted DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  branch      Branch            @relation(fields: [branchId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  adjustments StockAdjustment[]

  // Composite key to ensure unique inventory per branch-product combination
  @@unique([branchId, productId])
}

//
// ---------- STOCK ADJUSTMENTS ----------
//

model StockAdjustment {
  id             String         @id @default(cuid())
  tenantId       String
  inventoryId    String
  branchId       String
  productId      String
  type           AdjustmentType
  quantityChange Decimal        @db.Decimal(10, 4) // Amount changed (positive or negative)
  stockBefore    Decimal        @db.Decimal(10, 4) // Stock level before adjustment
  stockAfter     Decimal        @db.Decimal(10, 4) // Stock level after adjustment
  reason         String
  adjustedBy     String // User ID who made the adjustment
  createdAt      DateTime       @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  inventory Inventory @relation(fields: [inventoryId], references: [id])
  branch    Branch    @relation(fields: [branchId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  user      User      @relation("StockAdjustments", fields: [adjustedBy], references: [id])

  @@index([inventoryId])
  @@index([branchId, productId])
  @@index([createdAt])
}

//
// ---------- INVENTORY TRANSFERS ----------
//

model Transfer {
  id           String         @id @default(cuid())
  tenantId     String
  fromBranchId String
  toBranchId   String
  status       TransferStatus @default(PENDING)
  requestedBy  String // User ID who initiated the transfer
  approvedBy   String? // User ID who approved/completed the transfer
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  completedAt  DateTime?

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  fromBranch Branch         @relation("TransfersFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch         @relation("TransfersTo", fields: [toBranchId], references: [id])
  requestor  User           @relation("TransferRequests", fields: [requestedBy], references: [id])
  approver   User?          @relation("TransferApprovals", fields: [approvedBy], references: [id])
  items      TransferItem[]

  @@index([tenantId, status])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model TransferItem {
  id         String  @id @default(cuid())
  transferId String
  productId  String
  quantity   Decimal @db.Decimal(10, 4)

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([transferId, productId])
}

// 
// ---------- REFUNDS (Audit Trail) ----------
// 

model Refund {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Decimal  @default(0) @db.Decimal(10, 4)
  totalAmount Decimal  @default(0) @db.Decimal(10, 2)
  reason      String?
  refundedAt  DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  refundItems RefundItem[]
}

model RefundItem {
  id          String  @id @default(cuid())
  refundId    String
  orderItemId String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  refund    Refund    @relation(fields: [refundId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}

//
// ---------- RESTAURANT MODULE (TABLES) ----------
//
model Table {
  id          String  @id @default(cuid())
  tableNumber Int
  tenantId    String
  branchId    String
  name        String
  capacity    Int     @default(4)
  isActive    Boolean @default(true)
  isDeleted   Boolean @default(false)

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch  @relation(fields: [branchId], references: [id])
  orders Order[]
}

//
// ---------- MODIFIERS (Toppings/Add-ons) ----------
//
model ModifierGroup {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  type      ModifierType
  isDeleted Boolean      @default(false)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  modifiers Modifier[]
}

model Modifier {
  id        String  @id @default(cuid())
  tenantId  String
  groupId   String
  productId String? // optional parent product
  name      String
  price     Decimal @default(0)
  isDeleted Boolean @default(false)

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  group         ModifierGroup       @relation(fields: [groupId], references: [id])
  product       Product?            @relation(fields: [productId], references: [id])
  orderItemMods OrderItemModifier[]
}

//
// ---------- RECIPE (for restaurant inventory deduction) ----------
//
model Recipe {
  id           String  @id @default(cuid())
  tenantId     String
  productId    String // The finished product this recipe creates
  ingredientId String // The raw material (Product with isIngredient=true)
  quantity     Decimal @db.Decimal(10, 4) // Amount of ingredient required for one unit of product

  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  product    Product @relation("SellableRecipe", fields: [productId], references: [id])
  ingredient Product @relation("IngredientRecipe", fields: [ingredientId], references: [id])

  // Enforce unique ingredient per product (a product can only have one recipe per ingredient)
  @@unique([productId, ingredientId])
}

//
// ---------- ORDERS (Sales Transaction) ----------
//
model Order {
  id       String  @id @default(cuid())
  tenantId String
  userId   String? // Cashier/user who created the order
  branchId String
  tableId  String? // restaurant only
  deviceId String? // POS device that created the order

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id])

  orderNumber String? // Friendly ID (e.g. "1001")

  type   OrderType
  status OrderStatus @default(DRAFT) // Changed default to DRAFT

  // Financial fields
  subtotal  Decimal  @default(0) @db.Decimal(10, 2) // New: Total before tax/discount
  taxAmount Decimal  @default(0) @db.Decimal(10, 2) // New: Total tax collected
  total     Decimal  @default(0) @db.Decimal(10, 2) // Final amount due/paid
  discount  Decimal? @default(0) @db.Decimal(10, 2)

  createdAt   DateTime  @default(now())
  completedAt DateTime? // New: Timestamp for final closure/payment

  user     User?       @relation(fields: [userId], references: [id])
  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  branch   Branch      @relation(fields: [branchId], references: [id])
  table    Table?      @relation(fields: [tableId], references: [id])
  device   POSDevice?  @relation(fields: [deviceId], references: [id])
  items    OrderItem[]
  payments Payment[] // FIXED: Relation to new Payment model
  refunds  Refund[]

  @@index([tenantId, branchId, createdAt])
}

//
// ---------- ORDER ITEMS (Line Items) ----------
//

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Decimal @default(1) @db.Decimal(10, 4)
  unitPrice Decimal @db.Decimal(10, 2) // New: Price of one unit
  taxRate   Decimal @default(0) @db.Decimal(10, 2) // New: Tax rate at time of sale
  taxAmount Decimal @default(0) @db.Decimal(10, 2) // New: Calculated tax for this item
  total     Decimal @db.Decimal(10, 2) // Item subtotal (qty * unitPrice + taxAmount)
  // KDS tracking
  notes     String? // e.g., "Extra crispy"

  order       Order               @relation(fields: [orderId], references: [id])
  product     Product             @relation(fields: [productId], references: [id])
  modifiers   OrderItemModifier[]
  tickets     OrderItemTicket[] // FIXED: Relation to new KDS ticket model
  refundItems RefundItem[]
}

//
// ---------- KDS/TICKET TRACKING (Granular Kitchen Workflow) ----------
//
model OrderItemTicket {
  id          String      @id @default(cuid())
  orderItemId String
  station     String? // e.g., "Main Kitchen," "Bar"
  status      OrderStatus @default(SENT_TO_KITCHEN)

  // Important KDS Timestamps
  sentAt   DateTime  @default(now())
  bumpedAt DateTime? // Time it was removed/completed from the KDS screen

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}

//
// ---------- ORDER ITEM MODIFIERS ----------
//
model OrderItemModifier {
  id          String  @id @default(cuid())
  orderItemId String
  modifierId  String
  price       Decimal @db.Decimal(10, 2) // Price charged for this modifier

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  modifier  Modifier  @relation(fields: [modifierId], references: [id])
}

//
// ---------- PAYMENTS (Financial Compliance) ----------
//
model Payment {
  id            String        @id @default(cuid())
  orderId       String
  method        PaymentMethod
  currencyCode  String        @default("USD")
  amount        Decimal
  exchangeRate  Decimal? // Rate if foreign currency used (CRUCIAL for Lebanon)
  transactionId String? // Reference ID from card processor (Stripe, etc.)
  paidAt        DateTime      @default(now())

  order    Order    @relation(fields: [orderId], references: [id])
  currency Currency @relation(fields: [currencyCode], references: [code])
}

//
// ---------- CUSTOMERS (CRM) ----------
//
model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

  @@index([tenantId])
}

//
// ---------- SHIFTS (Cash Management) ----------
//
model Shift {
  id         String      @id @default(cuid())
  tenantId   String
  branchId   String
  userId     String // Cashier who opened the shift
  deviceId   String? // Device used
  startTime  DateTime    @default(now())
  endTime    DateTime?
  startCash  Decimal     @default(0) @db.Decimal(10, 2)
  endCash    Decimal?    @db.Decimal(10, 2) // Counted cash at close
  actualCash Decimal?    @db.Decimal(10, 2) // System calculated cash
  difference Decimal?    @db.Decimal(10, 2) // Over/Short amount
  status     ShiftStatus @default(OPEN)
  notes      String?

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  branch Branch     @relation(fields: [branchId], references: [id])
  user   User       @relation(fields: [userId], references: [id])
  device POSDevice? @relation(fields: [deviceId], references: [id])
  orders Order[]

  @@index([tenantId, branchId, status])
}

//
// ---------- TAXES ----------
//
model Tax {
  id        String  @id @default(cuid())
  tenantId  String
  name      String // e.g. "VAT", "Sales Tax"
  rate      Decimal @db.Decimal(5, 2) // e.g. 10.00
  isDefault Boolean @default(false)

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]
}
