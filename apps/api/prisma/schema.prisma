  SQUARE
  CIRCLE
  OVAL
  CUSTOM
}

model OrderSequence {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  date      String
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
}

//
// ---------- RESERVATIONS ----------
//
model Reservation {
  id                String  @id @default(uuid())
  reservationNumber String
  tenantId          String
  branchId          String
  customerId        String? // linked Customer when the guest is known; null for guest bookings
  customerName      String
  customerPhone     String
  customerEmail     String?
  tableId           String? // optional pre-assigned table; required to SEAT
  orderId           String? @unique // dine-in Order created when the reservation is seated
  guestCount        Int

  reservationDate    DateTime          @db.Date
  reservationTime    String
  reservationAt      DateTime
  durationMinutes    Int               @default(90)
  status             ReservationStatus @default(PENDING)
  source             ReservationSource @default(PHONE)
  notes              String?
  cancellationReason String?
  createdById        String?
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table     Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ReservationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([branchId, reservationNumber])
  @@index([tenantId, branchId, reservationDate])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId, tableId, reservationAt])
  @@index([tenantId, customerPhone])
  @@index([tenantId, reservationNumber])
  @@index([status, reservationAt]) // drives the no-show expiration sweep
  @@index([tableId])
}

model ReservationSequence {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  date      String
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  ARRIVED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  WALK_IN
  PHONE
  ONLINE
  ADMIN
}
