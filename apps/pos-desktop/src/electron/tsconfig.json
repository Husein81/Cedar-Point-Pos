{
    "compilerOptions": {
        "target": "ES2022",
        "forceConsistentCasingInFileNames": true,
        "module": "CommonJS",
        "outDir": "../../dist-electron",
        "types": [
            "node"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "**/*.d.ts"
    ]
}