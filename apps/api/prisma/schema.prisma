// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

//
// ---------- ENUMS ----------
//
enum UserRole {
    SYSTEM_ADMIN
    ADMIN
    MANAGER
    CASHIER
}

enum BusinessType {
    RETAIL
    RESTAURANT
}

enum InventoryChangeType {
    SET_STOCK // Direct stock set
    ADJUST_STOCK // Stock adjustment (increment/decrement)
    SET_MIN_STOCK // Minimum stock threshold change
    ORDER_DEDUCTION // Stock deducted when order placed (legacy)
    SALE // Stock sold through completed order
    REFUND // Stock returned from refund
    MANUAL_ADJUST // Manual adjustment
    TRANSFER_OUT // Stock transferred out
    TRANSFER_IN // Stock transferred in
}

enum OrderType {
    DINE_IN
    TAKEAWAY
    DELIVERY
    RETAIL
}

enum OrderStatus {
    DRAFT // New: For orders being built on the POS
    ON_HOLD // Order put on hold
    PENDING // Order created but not processed (no payment)
    PARTIALLY_PAID // Order with partial payment received
    CONFIRMED // Restaurant: Order confirmed by staff
    IN_PROGRESS // Restaurant: Order being prepared
    SENT_TO_KITCHEN // Order sent to kitchen/bar
    READY // Ready for pickup/serve
    PAID // Payment received, inventory deducted
    COMPLETED // Order fully completed
    CANCELLED
}

enum PaymentMethod {
    CASH
    CARD
    CREDIT
    VOUCHER
    ONLINE
}

enum ModifierType {
    SINGLE
    MULTIPLE
}

enum ShiftStatus {
    OPEN
    CLOSED
}

enum TransferStatus {
    PENDING
    IN_TRANSIT
    COMPLETED
    CANCELLED
}

//
// ---------- TENANT (Multi-Tenancy Root) ----------
//
model Tenant {
    id               String       @id @default(cuid())
    name             String
    businessType     BusinessType
    baseCurrencyCode String       @default("USD") // Base currency for accounting/reporting
    isActive         Boolean      @default(true)
    createdAt        DateTime     @default(now())
    updatedAt        DateTime     @updatedAt

    users            User[]
    branches         Branch[]
    products         Product[]
    inventory        Inventory[] // Inventory records still belong to the Tenant scope
    inventoryHistory InventoryHistory[]
    orders           Order[]
    tables           Table[]
    modifierGroups   ModifierGroup[]
    recipes          Recipe[]
    devices          POSDevice[]
    customers        Customer[]
    shifts           Shift[]
    transfers        Transfer[]
    settings         Json? // feature flags, tax rates, etc.
    modifiers        Modifier[]
    categories       Category[]
    tenantCurrencies TenantCurrency[] // Tenant-specific currency configurations
}

//
// ---------- CURRENCY (Reference Table) ----------
//
// Global currency definitions - serves as a reference/lookup table
// Actual tenant usage is tracked via TenantCurrency
model Currency {
    code             String           @id // ISO 4217 code: USD, EUR, LBP
    name             String // Full name: "United States Dollar"
    symbol           String? // Display symbol: "$", "€", "ل.ل"
    decimalPlaces    Int              @default(2) // Number of decimal places (0 for LBP)
    tenantCurrencies TenantCurrency[]
    payments         Payment[]
}

//
// ---------- TENANT CURRENCY (Tenant-Scoped Currency Config) ----------
//
// Each tenant has their own currency configuration with exchange rates
// Exchange rates are relative to the tenant's base currency
model TenantCurrency {
    id           String   @id @default(cuid())
    tenantId     String
    currencyCode String
    exchangeRate Decimal  @db.Decimal(18, 6) // Rate relative to base currency (e.g., 89500 for LBP/USD)
    isActive     Boolean  @default(true)
    isDefault    Boolean  @default(false) // Quick access flag - only one should be true (the base currency)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt // Tracks when exchange rate was last changed

    tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    currency Currency @relation(fields: [currencyCode], references: [code])

    // Each tenant can only have one configuration per currency
    @@unique([tenantId, isDefault], map: "one_base_currency_per_tenant")
    @@unique([tenantId, currencyCode])
    @@index([tenantId, isActive])
}

//
// ---------- USERS & AUTH ----------
//
model User {
    id                 String             @id @default(cuid())
    name               String
    email              String?            @unique
    username           String             @unique
    password           String
    role               UserRole           @default(CASHIER)
    isActive           Boolean            @default(true)
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
    tenantId           String?
    tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    orders             Order[]
    shifts             Shift[]
    inventoryHistory   InventoryHistory[]
    transfersRequested Transfer[]         @relation("TransferRequests")
    transfersApproved  Transfer[]         @relation("TransferApprovals")
}

//
// ---------- BRANCHES (Physical Locations) ----------
//
model Branch {
    id               String             @id @default(cuid())
    tenantId         String
    name             String
    address          String?
    phone            String?
    isDeleted        Boolean            @default(false) // Soft delete
    tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    tables           Table[]
    devices          POSDevice[]
    inventory        Inventory[] // Inventory is tracked at the Branch level
    orders           Order[]
    shifts           Shift[]
    inventoryHistory InventoryHistory[]
    transfersFrom    Transfer[]         @relation("TransfersFrom")
    transfersTo      Transfer[]         @relation("TransfersTo")
    products         Product[]
}

//
// ---------- POS DEVICES (For Sync & Auth) ----------
//
model POSDevice {
    id       String    @id @default(cuid())
    tenantId String
    branchId String
    name     String
    token    String    @unique // device authentication token
    lastSync DateTime?
    isActive Boolean   @default(true)
    isKDS    Boolean   @default(false) // New: Flag to identify Kitchen Display Systems
    tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
    orders   Order[]
    shifts   Shift[]
}

//
// ---------- PRODUCTS & INGREDIENTS ----------
//
model Category {
    id            String        @id @default(cuid())
    tenantId      String
    name          String
    code          String?       @unique
    description   String?
    isDeleted     Boolean       @default(false)
    tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    products      Product[]
    subcategories Subcategory[]
}

model Subcategory {
    id          String    @id @default(cuid())
    categoryId  String
    name        String
    description String?
    isDeleted   Boolean   @default(false)
    category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    products    Product[]
}

model Product {
    id               String             @id @default(cuid())
    tenantId         String
    branchId         String?
    name             String
    description      String?
    imageUrl         String?
    sku              String?            @unique
    barcode          String?            @unique // retail
    price            Decimal?           @default(0) @db.Decimal(10, 2)
    cost             Decimal?           @default(0) @db.Decimal(10, 2)
    categoryId       String?
    subcategoryId    String?
    isActive         Boolean            @default(true)
    isDeleted        Boolean            @default(false) // Soft delete
    isIngredient     Boolean            @default(false) // New: Differentiates raw ingredients from sellable items
    isModifiable     Boolean            @default(false) // restaurant
    createdAt        DateTime           @default(now())
    tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch           Branch?            @relation(fields: [branchId], references: [id], onDelete: Cascade)
    inventory        Inventory[]
    inventoryHistory InventoryHistory[]
    modifiers        Modifier[]
    recipesUsedIn    Recipe[]           @relation("SellableRecipe") // Recipe output product
    ingredientIn     Recipe[]           @relation("IngredientRecipe") // Product used as ingredient
    orderItems       OrderItem[]
    category         Category?          @relation(fields: [categoryId], references: [id])
    subcategory      Subcategory?       @relation(fields: [subcategoryId], references: [id])
    offerGroupItems  OfferGroupItem[]
    transferItems    TransferItem[]
}

// 
// ---------- OFFERS & DISCOUNTS (Future Enhancement) ----------
model Offer {
    id          String       @id @default(cuid())
    name        String
    basePrice   Decimal      @default(0) @db.Decimal(10, 2)
    offerGroups OfferGroup[]
}

model OfferGroup {
    id              String           @id @default(cuid())
    offerId         String
    name            String
    freeItemsCount  Int              @default(0)
    offer           Offer            @relation(fields: [offerId], references: [id])
    offerGroupItems OfferGroupItem[]
}

model OfferGroupItem {
    id           String     @id @default(cuid())
    offerGroupId String
    productId    String
    extraPrice   Decimal    @default(0) @db.Decimal(10, 2)
    offerGroup   OfferGroup @relation(fields: [offerGroupId], references: [id])
    product      Product    @relation(fields: [productId], references: [id])
}

//
// ---------- INVENTORY (Branch-Scoped) ----------
//
model Inventory {
    id           String   @id @default(cuid())
    tenantId     String
    branchId     String // FIXED: Link to Branch
    productId    String
    stock        Decimal  @default(0) @db.Decimal(10, 4)
    minStock     Decimal  @default(0) @db.Decimal(10, 4) // Minimum stock threshold for low stock alerts
    lastAdjusted DateTime @updatedAt
    tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
    product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

    // Composite key to ensure unique inventory per branch-product combination
    @@unique([branchId, productId])
}

//
// ---------- INVENTORY HISTORY (Audit Trail) ----------
//
model InventoryHistory {
    id             String              @id @default(cuid())
    tenantId       String
    branchId       String
    productId      String
    userId         String // User who made the change
    changeType     InventoryChangeType
    beforeStock    Decimal             @db.Decimal(10, 4) // Stock quantity before change
    afterStock     Decimal             @db.Decimal(10, 4) // Stock quantity after change
    adjustment     Decimal             @db.Decimal(10, 4) // Net change (afterStock - beforeStock)
    beforeMinStock Decimal?            @db.Decimal(10, 4) // Min stock before change (if applicable)
    afterMinStock  Decimal?            @db.Decimal(10, 4) // Min stock after change (if applicable)
    reason         String? // Reason for the adjustment
    referenceId    String? // Reference to order, refund, transfer, etc.
    referenceType  String? // Type of reference: ORDER, REFUND, TRANSFER
    createdAt      DateTime            @default(now())
    tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
    product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
    user           User                @relation(fields: [userId], references: [id])

    @@index([tenantId, branchId, createdAt])
    @@index([productId, createdAt])
    @@index([userId, createdAt])
    @@index([referenceId, referenceType])
}

//
// ---------- INVENTORY TRANSFERS ----------
//
model Transfer {
    id           String         @id @default(cuid())
    tenantId     String
    fromBranchId String
    toBranchId   String
    status       TransferStatus @default(PENDING)
    requestedBy  String // User ID who initiated the transfer
    approvedBy   String? // User ID who approved/completed the transfer
    notes        String?
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    completedAt  DateTime?
    tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    fromBranch   Branch         @relation("TransfersFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
    toBranch     Branch         @relation("TransfersTo", fields: [toBranchId], references: [id], onDelete: Cascade)
    requestor    User           @relation("TransferRequests", fields: [requestedBy], references: [id])
    approver     User?          @relation("TransferApprovals", fields: [approvedBy], references: [id])
    items        TransferItem[]

    @@index([tenantId, status])
    @@index([fromBranchId])
    @@index([toBranchId])
}

model TransferItem {
    id         String   @id @default(cuid())
    transferId String
    productId  String
    quantity   Decimal  @db.Decimal(10, 4)
    transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
    product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([transferId, productId])
}

// 
// ---------- REFUNDS (Audit Trail) ----------
// 
model Refund {
    id          String       @id @default(cuid())
    orderId     String
    totalAmount Decimal      @default(0) @db.Decimal(10, 2)
    reason      String?
    refundedAt  DateTime     @default(now())
    order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
    refundItems RefundItem[]
}

model RefundItem {
    id          String @id @default(cuid())
    refundId    String
    orderItemId String

    quantity  Decimal @db.Decimal(10, 4)
    unitPrice Decimal @db.Decimal(10, 2)
    subtotal  Decimal @db.Decimal(10, 2)

    refund    Refund    @relation(fields: [refundId], references: [id], onDelete: Cascade)
    orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

    @@unique([refundId, orderItemId])
    @@index([orderItemId])
}

//
// ---------- RESTAURANT MODULE (TABLES) ----------
//
model Table {
    id          String  @id @default(cuid())
    tableNumber Int
    tenantId    String
    branchId    String
    name        String
    capacity    Int     @default(4)
    isActive    Boolean @default(true)
    isDeleted   Boolean @default(false)
    tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch      Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
    orders      Order[]
}

//
// ---------- MODIFIERS (Toppings/Add-ons) ----------
//
model ModifierGroup {
    id        String       @id @default(cuid())
    tenantId  String
    name      String
    type      ModifierType
    isDeleted Boolean      @default(false)
    tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    modifiers Modifier[]
}

model Modifier {
    id            String              @id @default(cuid())
    tenantId      String
    groupId       String
    productId     String? // optional parent product
    name          String
    price         Decimal             @default(0)
    isDeleted     Boolean             @default(false)
    tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    group         ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
    product       Product?            @relation(fields: [productId], references: [id])
    orderItemMods OrderItemModifier[]
}

//
// ---------- RECIPE (for restaurant inventory deduction) ----------
//
model Recipe {
    id           String  @id @default(cuid())
    tenantId     String
    productId    String // The finished product this recipe creates
    ingredientId String // The raw material (Product with isIngredient=true)
    quantity     Decimal @db.Decimal(10, 4) // Amount of ingredient required for one unit of product
    tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    product      Product @relation("SellableRecipe", fields: [productId], references: [id])
    ingredient   Product @relation("IngredientRecipe", fields: [ingredientId], references: [id])

    // Enforce unique ingredient per product (a product can only have one recipe per ingredient)
    @@unique([productId, ingredientId])
}

//
// ---------- ORDERS (Sales Transaction) ----------
//
model Order {
    id          String      @id @default(cuid())
    tenantId    String
    userId      String? // Cashier/user who created the order
    branchId    String
    tableId     String? // restaurant only
    deviceId    String? // POS device that created the order
    customerId  String?
    customer    Customer?   @relation(fields: [customerId], references: [id])
    shiftId     String?
    shift       Shift?      @relation(fields: [shiftId], references: [id])
    orderNumber String? // Friendly ID (e.g. "1001")
    type        OrderType
    status      OrderStatus @default(DRAFT) // Changed default to DRAFT

    // Financial fields
    subtotal     Decimal     @default(0) @db.Decimal(10, 2) // New: Total before tax/discount
    total        Decimal     @default(0) @db.Decimal(10, 2) // Final amount due/paid
    discount     Decimal?    @default(0) @db.Decimal(10, 2)
    shippingFee  Decimal?    @default(0) @db.Decimal(10, 2)
    // Currency snapshot (for reporting optimization)
    currencyCode String?     @default("USD") // Tenant's base currency at time of order
    exchangeRate Decimal?    @db.Decimal(18, 6) // Exchange rate snapshot (1.0 for base currency)
    createdAt    DateTime    @default(now())
    completedAt  DateTime? // New: Timestamp for final closure/payment
    user         User?       @relation(fields: [userId], references: [id])
    tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch       Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
    table        Table?      @relation(fields: [tableId], references: [id])
    device       POSDevice?  @relation(fields: [deviceId], references: [id])
    items        OrderItem[]
    payments     Payment[] // FIXED: Relation to new Payment model
    refunds      Refund[]

    @@index([tenantId, branchId, createdAt])
}

//
// ---------- ORDER ITEMS (Line Items) ----------
//
model OrderItem {
    id          String              @id @default(cuid())
    orderId     String
    productId   String
    quantity    Decimal             @default(1) @db.Decimal(10, 4)
    unitPrice   Decimal             @db.Decimal(10, 2) // New: Price of one unit
    subtotal    Decimal             @default(0) @db.Decimal(10, 2) // New: Item subtotal (qty * unitPrice + modifiers)
    total       Decimal             @db.Decimal(10, 2) // Item total (subtotal + taxAmount)
    // KDS tracking
    notes       String? // e.g., "Extra crispy"
    order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
    modifiers   OrderItemModifier[]
    tickets     OrderItemTicket[] // FIXED: Relation to new KDS ticket model
    refundItems RefundItem[]
}

//
// ---------- KDS/TICKET TRACKING (Granular Kitchen Workflow) ----------
//
model OrderItemTicket {
    id          String      @id @default(cuid())
    orderItemId String
    station     String? // e.g., "Main Kitchen," "Bar"
    status      OrderStatus @default(SENT_TO_KITCHEN)
    // Important KDS Timestamps
    sentAt      DateTime    @default(now())
    bumpedAt    DateTime? // Time it was removed/completed from the KDS screen
    orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

//
// ---------- ORDER ITEM MODIFIERS ----------
//
model OrderItemModifier {
    id          String    @id @default(cuid())
    orderItemId String
    modifierId  String
    price       Decimal   @db.Decimal(10, 2) // Price charged for this modifier
    orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
    modifier    Modifier  @relation(fields: [modifierId], references: [id], onDelete: Cascade)
}

//
// ---------- PAYMENTS (Financial Compliance) ----------
//
model Payment {
    id            String        @id @default(cuid())
    orderId       String
    method        PaymentMethod
    currencyCode  String? // Optional - only needed for multi-currency support
    amount        Decimal
    exchangeRate  Decimal? // Rate if foreign currency used (CRUCIAL for Lebanon)
    transactionId String? // Reference ID from card processor (Stripe, etc.)
    paidAt        DateTime      @default(now())
    order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
    currency      Currency?     @relation(fields: [currencyCode], references: [code])
}

//
// ---------- CUSTOMERS (CRM) ----------
//
model Customer {
    id        String   @id @default(cuid())
    tenantId  String
    name      String
    email     String?
    phone     String?
    address   String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    orders    Order[]

    @@index([tenantId])
}

//
// ---------- SHIFTS (Cash Management) ----------
//
model Shift {
    id         String      @id @default(cuid())
    tenantId   String
    branchId   String
    userId     String // Cashier who opened the shift
    deviceId   String? // Device used
    startTime  DateTime    @default(now())
    endTime    DateTime?
    startCash  Decimal     @default(0) @db.Decimal(10, 2)
    endCash    Decimal?    @db.Decimal(10, 2) // Counted cash at close
    actualCash Decimal?    @db.Decimal(10, 2) // System calculated cash
    difference Decimal?    @db.Decimal(10, 2) // Over/Short amount
    status     ShiftStatus @default(OPEN)
    notes      String?
    tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
    user       User        @relation(fields: [userId], references: [id])
    device     POSDevice?  @relation(fields: [deviceId], references: [id])
    orders     Order[]

    @@index([tenantId, branchId, status])
}
