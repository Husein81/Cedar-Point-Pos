model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(10, 4)
  unitCost        Decimal       @db.Decimal(10, 2)
  totalCost       Decimal       @db.Decimal(10, 2)
  notes           String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, productId])
  @@index([purchaseOrderId])
  @@index([productId])
}

model Shift {
  id         String      @id @default(uuid())
  tenantId   String
  branchId   String
  userId     String
  deviceId   String?
  startTime  DateTime    @default(now())
  endTime    DateTime?
  startCash  Decimal     @default(0) @db.Decimal(10, 2)
  endCash    Decimal?    @db.Decimal(10, 2)
  actualCash Decimal?    @db.Decimal(10, 2)
  difference Decimal?    @db.Decimal(10, 2)
  status     ShiftStatus @default(OPEN)
  notes      String?

  // Close-related fields (populated at shift close)
  closedById      String?
  closeMode       ShiftCloseMode?
  closeResult     ShiftCloseResult?
  varianceAmount  Decimal?          @db.Decimal(10, 2)
  variancePercent Decimal?          @db.Decimal(10, 4)
  approvedById    String?
  approvalNote    String?

  orders           Order[]
  payments         Payment[]
  refunds          Refund[]
  cashMovements    CashMovement[]
  refundPayments   RefundPayment[]
  paymentSummaries ShiftPaymentSummary[]
  scheduleId       String?               @unique
  reportSnapshot   ShiftReportSnapshot?
  branch           Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  device           POSDevice?            @relation(fields: [deviceId], references: [id])
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id])
  closedBy         User?                 @relation("ShiftClosedBy", fields: [closedById], references: [id])
  approvedBy       User?                 @relation("ShiftApprovedBy", fields: [approvedById], references: [id])
  schedule         ShiftSchedule?        @relation(fields: [scheduleId], references: [id])

  @@index([tenantId, branchId, status])
  @@index([tenantId, deviceId, status])
}

//
// ---------- SHIFT PAYMENT SUMMARY ----------
//
model ShiftPaymentSummary {
  id           String        @id @default(uuid())
  shiftId      String
  method       PaymentMethod
  salesCount   Int           @default(0)
  salesTotal   Decimal       @default(0) @db.Decimal(10, 2)
  refundsCount Int           @default(0)
  refundsTotal Decimal       @default(0) @db.Decimal(10, 2)
  netTotal     Decimal       @default(0) @db.Decimal(10, 2)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([shiftId, method])
  @@index([shiftId])
}

//
// ---------- SHIFT REPORT SNAPSHOT (Z-REPORT) ----------
//
model ShiftReportSnapshot {
  id        String   @id @default(uuid())
  shiftId   String   @unique
  payload   Json // Full Z-report JSON snapshot
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

//
// ---------- SHIFT SCHEDULE (Planned Shifts) ----------
//
// One table, two mutually-exclusive kinds (discriminated by `isRecurring`):
//  - dated occurrence:  isRecurring=false, date set,  daysOfWeek empty, no effective window
//  - recurring pattern: isRecurring=true,  date NULL, daysOfWeek non-empty (times are
//    anchored to SHIFT_PATTERN_SENTINEL_DAY — only the time-of-day is meaningful)
// This invariant is enforced in-DB by the CHECK constraint `shift_schedule_kind_ck`
// (applied via raw SQL — Prisma does not model CHECK constraints; `db push` leaves it
// alone but will not recreate it, so re-apply after any `--force-reset`).
model ShiftSchedule {
  id            String              @id @default(uuid())
  tenantId      String
  branchId      String
  userId        String // Assigned employee
  deviceId      String? // Optional device assignment
  date          DateTime?           @db.Date // Occurrence date; NULL for recurring patterns
  isRecurring   Boolean             @default(false) // true = dateless weekly pattern
  daysOfWeek    Int[]               @default([]) // 0=Sun..6=Sat; populated for recurring patterns
  effectiveFrom DateTime?           @db.Date // Recurring: pattern applies from this day (null = open start)
  effectiveTo   DateTime?           @db.Date // Recurring: pattern applies until this day (null = ongoing)
  startTime     DateTime // Planned start (recurring: time-of-day on a sentinel date)
  endTime       DateTime // Planned end (recurring: time-of-day on a sentinel date)
  breakMinutes  Int                 @default(0) // Unpaid break subtracted from paid hours
  notes         String?
  status        ShiftScheduleStatus @default(DRAFT)
  publishedAt   DateTime?
  publishedById String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])
  device      POSDevice? @relation(fields: [deviceId], references: [id])
  publishedBy User?      @relation("SchedulePublishedBy", fields: [publishedById], references: [id])
  shift       Shift? // One runtime shift per schedule (1:1)

  @@unique([tenantId, userId, date, startTime])
  @@index([tenantId, branchId, date])
  @@index([tenantId, userId, date])
  @@index([tenantId, status])
}

//
// ---------- STAFF ACTIVITY LOG (Audit Trail) ----------
//
model StaffActivityLog {
  id        String   @id @default(uuid())
  staffId   String
  tenantId  String
  branchId  String?
  action    String // e.g. "REFUND_CREATED", "DISCOUNT_APPLIED", "ORDER_CANCELLED"
  module    String // e.g. "orders", "inventory", "shifts"
  metadata  Json? // { orderId, amount, reason, ... }
  createdAt DateTime @default(now())

  staff  User   @relation(fields: [staffId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([staffId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, module, createdAt])
}

//
// ---------- STAFF SESSION (POS PIN Login Sessions) ----------
//
model StaffSession {
  id        String    @id @default(uuid())
  staffId   String
  tenantId  String
  branchId  String
  deviceId  String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  isActive  Boolean   @default(true)

  staff  User   @relation(fields: [staffId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([staffId, isActive])
  @@index([tenantId, branchId, isActive])
}

