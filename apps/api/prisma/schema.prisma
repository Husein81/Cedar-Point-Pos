  MANAGER
  CASHIER
  KITCHEN
  WAITER // Restaurant floor staff
  DRIVER // Delivery staff
  INVENTORY_STAFF // Warehouse / stock staff
}

enum BusinessType {
  RETAIL
  RESTAURANT
}

enum InventoryChangeType {
  SET_STOCK
  ADJUST_STOCK
  SET_MIN_STOCK
  ORDER_DEDUCTION
  SALE
  REFUND
  MANUAL_ADJUST
  TRANSFER_OUT
  TRANSFER_IN
  PURCHASE_IN
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  RETAIL
}

// Fulfillment axis only — payment state lives in PaymentStatus.
enum OrderStatus {
  DRAFT
  PLACED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

// Derived server-side from payments/refunds vs total. Never client-set.
enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
}

// Kitchen ticket lifecycle (OrderItemTicket.status).
enum TicketStatus {
  QUEUED
  PREPARING
  READY
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
  VOUCHER
  ONLINE
}

enum ModifierType {
  SINGLE
  MULTIPLE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementReferenceType {
  PAYMENT
  REFUND
  ORDER
  SHIFT
  MANUAL
}

enum CashMovementType {
  CASH_IN // Manual cash deposit into drawer
  CASH_OUT // Manual cash withdrawal from drawer
  CASH_SALE // Cash received from sale payment
  CASH_CHANGE // Change given back to customer
  CASH_REFUND_OUT // Cash returned to customer for refund
  CASH_REFUND_CORRECTION // Cash correction for refund of non-cash payment
  OPENING_CASH // Starting cash for shift
}

enum ShiftCloseMode {
  NORMAL // Cashier sees expected before counting
  BLIND // Cashier counts first, then sees expected
}

enum ShiftCloseResult {
  BALANCED // Variance within threshold
  OVER // More cash than expected
  SHORT // Less cash than expected
  APPROVED // Manager approved despite variance
  NEEDS_APPROVAL // Variance exceeds threshold, awaiting approval
}

enum ShiftScheduleStatus {
  DRAFT // Not yet visible to staff
  PUBLISHED // Visible to assigned staff
  STARTED // Runtime shift opened from this schedule
  CANCELLED // Schedule revoked
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE // Table is free and ready for guests
  OCCUPIED // Table has active guests/order
  RESERVED // Table is reserved for upcoming guests
}

enum PurchaseOrderStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

enum LoyaltyEnrollmentMode {
  AUTO
  MANUAL
  INVITE_ONLY
}

enum LoyaltyTransactionType {
