generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ---------- TENANT (Multi-Tenancy Root) ----------
//
model Tenant {
  id               String       @id @default(cuid())
  name             String
  businessType     BusinessType
  baseCurrencyCode String       @default("USD") // Base currency for accounting/reporting
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users               User[]
  branches            Branch[]
  products            Product[]
  inventory           Inventory[] // Inventory records still belong to the Tenant scope
  inventoryHistory    InventoryHistory[]
  orders              Order[]
  tables              Table[]
  floors              Floor[] // Restaurant floor layouts
  modifierGroups      ModifierGroup[]
  devices             POSDevice[]
  customers           Customer[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  shifts              Shift[]
  transfers           Transfer[]
  settings            Json? // feature flags, tax rates, etc.
  modifiers           Modifier[]
  categories          Category[]
  tenantCurrencies    TenantCurrency[] // Tenant-specific currency configurations
  colors              Color[]
  loyaltyProgram      LoyaltyProgram?
  loyaltyAccounts     LoyaltyAccount[]
  loyaltyTransactions LoyaltyTransaction[]
  offers              Offer[]
  refunds             Refund[]
  cashMovements       CashMovement[]
}

model Currency {
  code             String           @id
  name             String
  symbol           String?
  decimalPlaces    Int              @default(2)
  payments         Payment[]
  tenantCurrencies TenantCurrency[]
}

model TenantCurrency {
  id           String   @id @default(cuid())
  tenantId     String
  currencyCode String
  exchangeRate Decimal  @db.Decimal(18, 6)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  currency     Currency @relation(fields: [currencyCode], references: [code])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, isDefault], map: "one_base_currency_per_tenant")
  @@unique([tenantId, currencyCode])
  @@index([tenantId, isActive])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String?              @unique
  username            String               @unique
  password            String
  role                UserRole             @default(CASHIER)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenantId            String?
  inventoryHistory    InventoryHistory[]
  orders              Order[]
  shifts              Shift[]
  transfersApproved   Transfer[]           @relation("TransferApprovals")
  transfersRequested  Transfer[]           @relation("TransferRequests")
  loyaltyTransactions LoyaltyTransaction[] @relation("UserLoyaltyTransactions")
  payments            Payment[]
  shiftsClosedBy      Shift[]              @relation("ShiftClosedBy")
  shiftsApprovedBy    Shift[]              @relation("ShiftApprovedBy")
  cashMovements       CashMovement[]
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Branch {
  id               String             @id @default(cuid())
  tenantId         String
  name             String
  address          String?
  phone            String?
  isDeleted        Boolean            @default(false) // Soft delete
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables           Table[]
  floors           Floor[] // Restaurant floor layouts
  devices          POSDevice[]
  inventory        Inventory[] // Inventory is tracked at the Branch level
  orders           Order[]
  shifts           Shift[]
  inventoryHistory InventoryHistory[]
  transfersFrom    Transfer[]         @relation("TransfersFrom")
  transfersTo      Transfer[]         @relation("TransfersTo")
  products         Product[]
  purchaseOrders   PurchaseOrder[]
  refunds          Refund[]
  cashMovements    CashMovement[]
}

model POSDevice {
  id            String         @id @default(cuid())
  tenantId      String
  branchId      String
  name          String
  token         String         @unique
  lastSync      DateTime?
  isActive      Boolean        @default(true)
  isKDS         Boolean        @default(false)
  orders        Order[]
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts        Shift[]
  payments      Payment[]
  cashMovements CashMovement[]
}

model Category {
  id            String        @id @default(cuid())
  tenantId      String
  name          String
  code          String?       @unique
  description   String?
  isDeleted     Boolean       @default(false)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products      Product[]
  subcategories Subcategory[]
  colorId       String?
  color         Color?        @relation(fields: [colorId], references: [id])
}

model Color {
  id         String     @id @default(cuid())
  name       String
  hex        String
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories Category[]

  @@unique([tenantId, hex])
  @@unique([tenantId, name])
}

model Subcategory {
  id          String    @id @default(cuid())
  categoryId  String
  name        String
  description String?
  isDeleted   Boolean   @default(false)
  products    Product[]
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String                      @id @default(cuid())
  tenantId            String
  name                String
  description         String?
  imageUrl            String?
  sku                 String?                     @unique
  barcode             String?                     @unique
  price               Decimal?                    @default(0) @db.Decimal(10, 2)
  cost                Decimal?                    @default(0) @db.Decimal(10, 2)
  categoryId          String?
  subcategoryId       String?
  isActive            Boolean                     @default(true)
  isDeleted           Boolean                     @default(false)
  isModifiable        Boolean                     @default(false)
  createdAt           DateTime                    @default(now())
  branchId            String?
  inventory           Inventory[]
  inventoryHistory    InventoryHistory[]
  modifiers           Modifier[]
  modifierAssignments ModifierProductAssignment[]
  offerGroupItems     OfferGroupItem[]
  orderItems          OrderItem[]
  branch              Branch?                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category            Category?                   @relation(fields: [categoryId], references: [id])
  subcategory         Subcategory?                @relation(fields: [subcategoryId], references: [id])
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  RefundItem          RefundItem[]
  transferItems       TransferItem[]
  purchaseOrderItems  PurchaseOrderItem[]
}

model Offer {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  basePrice   Decimal      @default(0) @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offerGroups OfferGroup[]

  @@index([tenantId])
}

model OfferGroup {
  id              String           @id @default(cuid())
  offerId         String
  name            String
  freeItemsCount  Int              @default(0)
  offer           Offer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerGroupItems OfferGroupItem[]

  @@index([offerId])
}

model OfferGroupItem {
  id           String     @id @default(cuid())
  offerGroupId String
  productId    String
  extraPrice   Decimal    @default(0) @db.Decimal(10, 2)
  offerGroup   OfferGroup @relation(fields: [offerGroupId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])

  @@unique([offerGroupId, productId])
}

model Inventory {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  productId    String
  stock        Decimal  @default(0) @db.Decimal(10, 4)
  minStock     Decimal  @default(0) @db.Decimal(10, 4)
  lastAdjusted DateTime @updatedAt
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
}

model InventoryHistory {
  id             String              @id @default(cuid())
  tenantId       String
  branchId       String
  productId      String
  userId         String
  changeType     InventoryChangeType
  beforeStock    Decimal             @db.Decimal(10, 4)
  afterStock     Decimal             @db.Decimal(10, 4)
  adjustment     Decimal             @db.Decimal(10, 4)
  beforeMinStock Decimal?            @db.Decimal(10, 4)
  afterMinStock  Decimal?            @db.Decimal(10, 4)
  reason         String?
  createdAt      DateTime            @default(now())
  referenceId    String?
  referenceType  String?
  branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([referenceId, referenceType])
}

model Transfer {
  id           String         @id @default(cuid())
  tenantId     String
  fromBranchId String
  toBranchId   String
  status       TransferStatus @default(PENDING)
  requestedBy  String
  approvedBy   String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  completedAt  DateTime?
  approver     User?          @relation("TransferApprovals", fields: [approvedBy], references: [id])
  fromBranch   Branch         @relation("TransfersFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  requestor    User           @relation("TransferRequests", fields: [requestedBy], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  toBranch     Branch         @relation("TransfersTo", fields: [toBranchId], references: [id], onDelete: Cascade)
  items        TransferItem[]

  @@index([tenantId, status])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model TransferItem {
  id         String   @id @default(cuid())
  transferId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 4)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@unique([transferId, productId])
}

model Refund {
  id                    String   @id @default(cuid())
  orderId               String?
  totalAmount           Decimal  @default(0) @db.Decimal(10, 2)
  reason                String?
  refundedAt            DateTime @default(now())
  manualRefund          Boolean  @default(false)
  paymentMethod         String?
  loyaltyPointsRestored Int      @default(0)
  loyaltyPointsReversed Int      @default(0)

  // Shift attribution (optional for backward compatibility)
  tenantId       String?
  branchId       String?
  shiftId        String?
  deviceId       String?
  userId         String?
  idempotencyKey String?

  order               Order?               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refundItems         RefundItem[]
  refundPayments      RefundPayment[]
  loyaltyTransactions LoyaltyTransaction[] @relation("RefundLoyaltyTransactions")
  shift               Shift?               @relation(fields: [shiftId], references: [id])
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([shiftId])
  @@index([tenantId, refundedAt])
}

model RefundItem {
  id          String     @id @default(cuid())
  refundId    String
  orderItemId String?
  quantity    Decimal    @db.Decimal(10, 4)
  unitPrice   Decimal    @db.Decimal(10, 2)
  subtotal    Decimal    @db.Decimal(10, 2)
  productId   String?
  productName String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  Product     Product?   @relation(fields: [productId], references: [id])
  refund      Refund     @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([productId])
  @@index([refundId])
}

model RefundPayment {
  id           String        @id @default(cuid())
  refundId     String
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  currencyCode String?
  exchangeRate Decimal?      @db.Decimal(18, 6)

  // Attribution
  shiftId  String?
  deviceId String?
  userId   String?

  createdAt DateTime @default(now())

  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)
  shift  Shift? @relation(fields: [shiftId], references: [id])

  @@index([refundId])
  @@index([shiftId])
}

//
// ---------- CASH MOVEMENT LEDGER ----------
//
model CashMovement {
  id             String                     @id @default(cuid())
  tenantId       String
  branchId       String
  shiftId        String
  deviceId       String?
  userId         String
  type           CashMovementType
  amount         Decimal                    @db.Decimal(10, 2)
  reason         String?
  referenceId    String? // orderId, refundId, or paymentId
  referenceType  CashMovementReferenceType? // Normalized reference type
  idempotencyKey String?
  createdAt      DateTime                   @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift  Shift      @relation(fields: [shiftId], references: [id])
  device POSDevice? @relation(fields: [deviceId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([shiftId, type])
  @@index([tenantId, branchId, createdAt])
  @@index([referenceId, referenceType])
}

//
// ---------- RESTAURANT MODULE (FLOORS & TABLES) ----------
//
model Floor {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String
  name      String
  order     Int      @default(0) // For UI ordering
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables Table[]

  @@index([branchId, isDeleted])
}

model Table {
  id          String      @id @default(cuid())
  tableNumber Int
  tenantId    String
  branchId    String
  floorId     String? // Optional floor assignment
  name        String
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  isActive    Boolean     @default(true)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  floor  Floor?  @relation(fields: [floorId], references: [id], onDelete: SetNull)
  orders Order[]

  @@index([branchId, isDeleted])
  @@index([floorId])
}

model ModifierGroup {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  type      ModifierType
  isDeleted Boolean      @default(false)
  modifiers Modifier[]
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Modifier {
  id                 String                      @id @default(cuid())
  tenantId           String
  groupId            String
  productId          String? // @deprecated - kept for backward compatibility
  name               String
  price              Decimal                     @default(0)
  isDeleted          Boolean                     @default(false)
  group              ModifierGroup               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product            Product?                    @relation(fields: [productId], references: [id])
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItemMods      OrderItemModifier[]
  productAssignments ModifierProductAssignment[]
}

model ModifierProductAssignment {
  id         String   @id @default(cuid())
  modifierId String
  productId  String
  createdAt  DateTime @default(now())

  modifier Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([modifierId, productId])
  @@index([modifierId])
  @@index([productId])
}

model Order {
  id                              String               @id @default(cuid())
  tenantId                        String
  userId                          String?
  branchId                        String
  tableId                         String?
  deviceId                        String?
  customerId                      String?
  shiftId                         String?
  orderNumber                     String?
  type                            OrderType
  status                          OrderStatus          @default(DRAFT)
  subtotal                        Decimal              @default(0) @db.Decimal(10, 2)
  total                           Decimal              @default(0) @db.Decimal(10, 2)
  discount                        Decimal?             @default(0) @db.Decimal(10, 2)
  createdAt                       DateTime             @default(now())
  completedAt                     DateTime?
  shippingFee                     Decimal?             @default(0) @db.Decimal(10, 2)
  currencyCode                    String?              @default("USD")
  exchangeRate                    Decimal?             @db.Decimal(18, 6)
  includeVAT                      Boolean              @default(false)
  vat                             Decimal?             @default(0) @db.Decimal(10, 2)
  loyaltyRedeemedPoints           Int                  @default(0)
  loyaltyRedeemedAmount           Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyEarnedPoints             Int                  @default(0)
  loyaltyEligibleBaseAtCompletion Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyRedeemBaseAtCompletion   Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyProgramSnapshot          Json?
  loyaltyCompletedAt              DateTime?
  branch                          Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer                        Customer?            @relation(fields: [customerId], references: [id])
  device                          POSDevice?           @relation(fields: [deviceId], references: [id])
  shift                           Shift?               @relation(fields: [shiftId], references: [id])
  table                           Table?               @relation(fields: [tableId], references: [id])
  tenant                          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                            User?                @relation(fields: [userId], references: [id])
  items                           OrderItem[]
  payments                        Payment[]
  refunds                         Refund[]
  loyaltyTransactions             LoyaltyTransaction[] @relation("OrderLoyaltyTransactions")

  @@index([tenantId, branchId, createdAt])
}

model OrderItem {
  id          String              @id @default(cuid())
  orderId     String
  productId   String
  quantity    Decimal             @default(1) @db.Decimal(10, 4)
  unitPrice   Decimal             @db.Decimal(10, 2)
  subtotal    Decimal             @default(0) @db.Decimal(10, 2)
  total       Decimal             @db.Decimal(10, 2)
  notes       String?
  discount    Json?
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifiers   OrderItemModifier[]
  tickets     OrderItemTicket[]
  refundItems RefundItem[]
}

model OrderItemTicket {
  id          String      @id @default(cuid())
  orderItemId String
  station     String?
  status      OrderStatus @default(SENT_TO_KITCHEN)
  sentAt      DateTime    @default(now())
  bumpedAt    DateTime?
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  modifierId  String
  price       Decimal   @db.Decimal(10, 2)
  modifier    Modifier  @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  method        PaymentMethod
  currencyCode  String?
  amount        Decimal
  exchangeRate  Decimal?
  transactionId String?
  paidAt        DateTime      @default(now())

  // Shift attribution (optional for backward compatibility)
  shiftId        String?
  deviceId       String?
  userId         String?
  idempotencyKey String?

  currency Currency?  @relation(fields: [currencyCode], references: [code])
  order    Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shift    Shift?     @relation(fields: [shiftId], references: [id])
  device   POSDevice? @relation(fields: [deviceId], references: [id])
  user     User?      @relation(fields: [userId], references: [id])

  @@unique([orderId, idempotencyKey])
  @@index([shiftId])
  @@index([orderId])
}

model Customer {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  email               String?
  phone               String?
  address             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders              Order[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]

  @@index([tenantId])
}

model LoyaltyProgram {
  id                     String                @id @default(cuid())
  tenantId               String                @unique
  isEnabled              Boolean               @default(false)
  enrollmentMode         LoyaltyEnrollmentMode @default(AUTO)
  earnPointsPerCurrency  Decimal?              @db.Decimal(10, 4)
  redeemPointsStep       Int?
  redeemCurrencyPerStep  Decimal?              @db.Decimal(10, 2)
  minRedeemPoints        Int                   @default(0)
  maxRedeemPercent       Decimal?              @db.Decimal(5, 2)
  allowNoCustomerAccrual Boolean               @default(false)
  pointsExpirationDays   Int?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isEnabled])
}

model LoyaltyAccount {
  id               String               @id @default(cuid())
  tenantId         String
  customerId       String               @unique
  pointsBalance    Int                  @default(0)
  lifetimeEarned   Int                  @default(0)
  lifetimeRedeemed Int                  @default(0)
  lifetimeRestored Int                  @default(0)
  lifetimeReversed Int                  @default(0)
  lifetimeAdjusted Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions     LoyaltyTransaction[]

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, pointsBalance])
}

model LoyaltyTransaction {
  id             String                 @id @default(cuid())
  tenantId       String
  accountId      String
  customerId     String
  orderId        String?
  refundId       String?
  type           LoyaltyTransactionType
  direction      LoyaltyDirection
  points         Int
  moneyAmount    Decimal?               @db.Decimal(10, 2)
  balanceAfter   Int
  idempotencyKey String                 @unique
  reason         String?
  metadata       Json?
  actorUserId    String?
  createdAt      DateTime               @default(now())
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account        LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer       Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order          Order?                 @relation("OrderLoyaltyTransactions", fields: [orderId], references: [id], onDelete: SetNull)
  refund         Refund?                @relation("RefundLoyaltyTransactions", fields: [refundId], references: [id], onDelete: SetNull)
  actorUser      User?                  @relation("UserLoyaltyTransactions", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([accountId, createdAt])
  @@index([orderId])
  @@index([refundId])
}

//
// ---------- SUPPLIER MODULE ----------
//
model Supplier {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  companyName    String?
  phone          String?
  email          String?
  address        String?
  category       String? // Custom category (user-defined)
  currentBalance Decimal         @default(0) @db.Decimal(10, 2)
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  branchId    String
  supplierId  String
  orderNumber String?
  totalAmount Decimal             @default(0) @db.Decimal(10, 2)
  status      PurchaseOrderStatus @default(PENDING)
  notes       String?
  orderedAt   DateTime            @default(now())
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items       PurchaseOrderItem[]

  @@index([tenantId, supplierId])
  @@index([tenantId, branchId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(10, 4)
  unitCost        Decimal       @db.Decimal(10, 2)
  totalCost       Decimal       @db.Decimal(10, 2)
  notes           String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseOrderId, productId])
  @@index([purchaseOrderId])
  @@index([productId])
}

model Shift {
  id         String      @id @default(cuid())
  tenantId   String
  branchId   String
  userId     String
  deviceId   String?
  startTime  DateTime    @default(now())
  endTime    DateTime?
  startCash  Decimal     @default(0) @db.Decimal(10, 2)
  endCash    Decimal?    @db.Decimal(10, 2)
  actualCash Decimal?    @db.Decimal(10, 2)
  difference Decimal?    @db.Decimal(10, 2)
  status     ShiftStatus @default(OPEN)
  notes      String?

  // Close-related fields (populated at shift close)
  closedById      String?
  closeMode       ShiftCloseMode?
  closeResult     ShiftCloseResult?
  varianceAmount  Decimal?          @db.Decimal(10, 2)
  variancePercent Decimal?          @db.Decimal(10, 4)
  approvedById    String?
  approvalNote    String?

  orders           Order[]
  payments         Payment[]
  refunds          Refund[]
  cashMovements    CashMovement[]
  refundPayments   RefundPayment[]
  paymentSummaries ShiftPaymentSummary[]
  reportSnapshot   ShiftReportSnapshot?
  branch           Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  device           POSDevice?            @relation(fields: [deviceId], references: [id])
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id])
  closedBy         User?                 @relation("ShiftClosedBy", fields: [closedById], references: [id])
  approvedBy       User?                 @relation("ShiftApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId, branchId, status])
  @@index([tenantId, deviceId, status])
}

//
// ---------- SHIFT PAYMENT SUMMARY ----------
//
model ShiftPaymentSummary {
  id           String        @id @default(cuid())
  shiftId      String
  method       PaymentMethod
  salesCount   Int           @default(0)
  salesTotal   Decimal       @default(0) @db.Decimal(10, 2)
  refundsCount Int           @default(0)
  refundsTotal Decimal       @default(0) @db.Decimal(10, 2)
  netTotal     Decimal       @default(0) @db.Decimal(10, 2)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([shiftId, method])
  @@index([shiftId])
}

//
// ---------- SHIFT REPORT SNAPSHOT (Z-REPORT) ----------
//
model ShiftReportSnapshot {
  id        String   @id @default(cuid())
  shiftId   String   @unique
  payload   Json // Full Z-report JSON snapshot
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SYSTEM_ADMIN
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
}

enum BusinessType {
  RETAIL
  RESTAURANT
}

enum InventoryChangeType {
  SET_STOCK
  ADJUST_STOCK
  SET_MIN_STOCK
  ORDER_DEDUCTION
  SALE
  REFUND
  MANUAL_ADJUST
  TRANSFER_OUT
  TRANSFER_IN
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  RETAIL
}

enum OrderStatus {
  DRAFT
  ON_HOLD
  PENDING
  PARTIALLY_PAID
  CONFIRMED
  IN_PROGRESS
  SENT_TO_KITCHEN
  READY
  PAID
  COMPLETED
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
  VOUCHER
  ONLINE
}

enum ModifierType {
  SINGLE
  MULTIPLE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum CashMovementReferenceType {
  PAYMENT
  REFUND
  ORDER
  SHIFT
  MANUAL
}

enum CashMovementType {
  CASH_IN // Manual cash deposit into drawer
  CASH_OUT // Manual cash withdrawal from drawer
  CASH_SALE // Cash received from sale payment
  CASH_CHANGE // Change given back to customer
  CASH_REFUND_OUT // Cash returned to customer for refund
  CASH_REFUND_CORRECTION // Cash correction for refund of non-cash payment
  OPENING_CASH // Starting cash for shift
}

enum ShiftCloseMode {
  NORMAL // Cashier sees expected before counting
  BLIND // Cashier counts first, then sees expected
}

enum ShiftCloseResult {
  BALANCED // Variance within threshold
  OVER // More cash than expected
  SHORT // Less cash than expected
  APPROVED // Manager approved despite variance
  NEEDS_APPROVAL // Variance exceeds threshold, awaiting approval
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE // Table is free and ready for guests
  OCCUPIED // Table has active guests/order
  RESERVED // Table is reserved for upcoming guests
}

enum PurchaseOrderStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

enum LoyaltyEnrollmentMode {
  AUTO
  MANUAL
  INVITE_ONLY
}

enum LoyaltyTransactionType {
  EARN
