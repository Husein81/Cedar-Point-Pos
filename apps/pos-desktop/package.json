{
  "name": "cedar-point-pos",
  "productName": "CedarPoint POS",
  "version": "1.0.0",
  "description": "CedarPoint is an offline-first POS system for retail and restaurants.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Husein81/Cedar-Point-Pos.git"
  },
  "private": true,
  "author": {
    "name": "Cedar Core",
    "email": "support@cedarcore.io"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "renderer:dev": "vite",
    "watch:main": "vite build --config vite.main.config.ts --watch",
    "watch:preload": "vite build --config vite.preload.config.ts --watch",
    "electron:dev": "cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "dev": "npm-run-all --parallel build:main build:preload && npm-run-all --race --parallel renderer:dev watch:main watch:preload electron:dev",
    "package": "npm-run-all --parallel build:renderer build:main build:preload && electron-builder --config electron-builder.config.cjs --dir",
    "make": "npm-run-all --parallel build:renderer build:main build:preload && electron-builder --config electron-builder.config.cjs",
    "publish": "npm-run-all --parallel build:renderer build:main build:preload && electron-builder --config electron-builder.config.cjs --publish always",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "lodash": "^4.17.21",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/router-plugin": "^1.143.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "39.8.10",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^24.1.3",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^2.1.8"
  }
}
