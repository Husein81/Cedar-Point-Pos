{
  "extends": "@repo/typescript-config/vite.json",
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../dist-react",
    "types": [
      "vite/client",
      "vitest/globals"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/types": [
        "../../packages/types/src/index"
      ],
      "@repo/ui": [
        "../../packages/ui/src/index"
      ]
    }
  },
}