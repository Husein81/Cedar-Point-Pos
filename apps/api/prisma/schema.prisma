// =============================================================================
// SYSTEM SCHEMA (public) - Global tables shared across all tenants
// =============================================================================
//
// ARCHITECTURE OVERVIEW:
// ----------------------
// This file defines the SYSTEM/GLOBAL layer that lives in the PostgreSQL 
// `public` schema. These tables are:
//   - Tenant registry (master list of all tenants and their schema names)
//   - License management
//   - System-level device activation
//   - Future admin/system tables
//
// These tables are NEVER duplicated per tenant. They are accessed directly
// without schema switching.
//
// The application uses `search_path` to route tenant-specific queries to
// the appropriate schema (e.g., `t_abc123`), while global queries always
// target the `public` schema explicitly.
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "tenant"]
}

// =============================================================================
// ENUMS (System-level)
// =============================================================================

enum TenantStatus {
    ACTIVE // Tenant is active and can operate normally
    SUSPENDED // Tenant is suspended (e.g., payment issues)
    TRIAL // Tenant is in trial period
    ONBOARDING // Tenant is being provisioned (schema creation in progress)
    TERMINATED // Tenant is terminated (soft delete, data retained)

    @@schema("public")
}

enum BusinessType {
    RETAIL
    RESTAURANT

    @@schema("public")
}

enum LicenseType {
    TRIAL
    BASIC
    PROFESSIONAL
    ENTERPRISE

    @@schema("public")
}

enum DeviceActivationStatus {
    PENDING // Device registered but not yet activated
    ACTIVE // Device is active and licensed
    SUSPENDED // Device temporarily suspended
    REVOKED // Device license revoked

    @@schema("public")
}

// =============================================================================
// TENANT REGISTRY
// =============================================================================
// Master record for each tenant. The `schemaName` field stores the PostgreSQL
// schema where all tenant data resides (e.g., "t_abc123").
// =============================================================================

model Tenant {
    id           String       @id @default(cuid())
    name         String
    slug         String       @unique // URL-friendly identifier
    businessType BusinessType
    schemaName   String       @unique // PostgreSQL schema name (e.g., "t_abc123")
    status       TenantStatus @default(ONBOARDING)
    settings     Json? // Feature flags, configuration

    // Metadata
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    activatedAt DateTime? // When tenant was fully provisioned
    suspendedAt DateTime? // When tenant was suspended (if applicable)

    // Relations
    licenses License[]
    devices  SystemDevice[]

    @@index([status])
    @@index([slug])
    @@schema("public")
}

// =============================================================================
// LICENSE MANAGEMENT
// =============================================================================
// Tracks subscription/license information per tenant
// =============================================================================

model License {
    id          String      @id @default(cuid())
    tenantId    String
    type        LicenseType @default(TRIAL)
    maxDevices  Int         @default(1) // Maximum allowed devices
    maxBranches Int         @default(1) // Maximum allowed branches
    maxUsers    Int         @default(5) // Maximum allowed users

    // Validity
    startsAt  DateTime  @default(now())
    expiresAt DateTime?
    isActive  Boolean   @default(true)

    // Metadata
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId, isActive])
    @@schema("public")
}

// =============================================================================
// SYSTEM DEVICE REGISTRY
// =============================================================================
// Global device activation/licensing table. This tracks which devices are
// registered and activated across the entire system. The actual device
// configuration and operational data lives in the tenant schema.
// =============================================================================

model SystemDevice {
    id          String                 @id @default(cuid())
    tenantId    String
    deviceCode  String                 @unique // Unique activation code
    name        String
    fingerprint String? // Hardware fingerprint for validation
    status      DeviceActivationStatus @default(PENDING)

    // Activation tracking
    activatedAt   DateTime?
    lastHeartbeat DateTime?

    // Metadata
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

    @@index([tenantId, status])
    @@index([deviceCode])
    @@schema("public")
}

// =============================================================================
// AUDIT LOG (System-level)
// =============================================================================
// Tracks system-level administrative actions (tenant management, etc.)
// =============================================================================

model SystemAuditLog {
    id         String   @id @default(cuid())
    action     String // e.g., "TENANT_CREATED", "TENANT_SUSPENDED"
    entityType String // e.g., "Tenant", "License"
    entityId   String
    actorId    String? // User/system that performed the action
    actorEmail String?
    details    Json? // Additional context
    ipAddress  String?
    createdAt  DateTime @default(now())

    @@index([entityType, entityId])
    @@index([actorId])
    @@index([createdAt])
    @@schema("public")
}


// =============================================================================
// TENANT SCHEMA (per-tenant data)
// =============================================================================

// =============================================================================
// ENUMS (Tenant-level)
// =============================================================================

enum UserRole {
    OWNER
    ADMIN
    MANAGER
    CASHIER
    KITCHEN

    @@schema("tenant")
}

enum InventoryChangeType {
    SET_STOCK
    ADJUST_STOCK
    SET_MIN_STOCK
    ORDER_DEDUCT
    ORDER_RETURN
    MANUAL_ADJUST

    @@schema("tenant")
}

enum OrderType {
    DINE_IN
    TAKEAWAY
    DELIVERY

    @@schema("tenant")
}

enum OrderStatus {
    DRAFT
    PENDING
    SENT_TO_KITCHEN
    READY
    COMPLETED
    CANCELLED

    @@schema("tenant")
}

enum PaymentMethod {
    CASH
    CARD
    CREDIT
    VOUCHER
    ONLINE

    @@schema("tenant")
}

enum ModifierType {
    SINGLE
    MULTIPLE

    @@schema("tenant")
}

enum ShiftStatus {
    OPEN
    CLOSED

    @@schema("tenant")
}

enum TransferStatus {
    PENDING
    IN_TRANSIT
    COMPLETED
    CANCELLED

    @@schema("tenant")
}

// =============================================================================
// USERS & AUTH
// =============================================================================
// Note: No tenantId - users belong to the tenant whose schema they're in
// =============================================================================

model User {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    password  String
    role      UserRole @default(CASHIER)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations (all tenant-internal)
    orders             Order[]
    shifts             Shift[]
    inventoryHistory   InventoryHistory[]
    transfersRequested Transfer[]         @relation("TransferRequests")
    transfersApproved  Transfer[]         @relation("TransferApprovals")

    @@schema("tenant")
}

// =============================================================================
// BRANCHES (Physical Locations)
// =============================================================================
// No tenantId - each tenant schema has its own branches
// =============================================================================

model Branch {
    id        String  @id @default(cuid())
    name      String
    address   String?
    phone     String?
    isDeleted Boolean @default(false)

    // Relations
    tables           Table[]
    devices          POSDevice[]
    inventory        Inventory[]
    orders           Order[]
    shifts           Shift[]
    inventoryHistory InventoryHistory[]
    transfersFrom    Transfer[]         @relation("TransfersFrom")
    transfersTo      Transfer[]         @relation("TransfersTo")

    @@schema("tenant")
}

// =============================================================================
// POS DEVICES
// =============================================================================
// Operational device data within the tenant schema.
// Activation/licensing is tracked in the system schema (SystemDevice).
// =============================================================================

model POSDevice {
    id       String    @id @default(cuid())
    branchId String
    name     String
    token    String    @unique
    lastSync DateTime?
    isActive Boolean   @default(true)
    isKDS    Boolean   @default(false)

    // Relations
    branch Branch  @relation(fields: [branchId], references: [id])
    orders Order[]
    shifts Shift[]

    @@schema("tenant")
}

// =============================================================================
// CATEGORIES & PRODUCTS
// =============================================================================

model Category {
    id          String  @id @default(cuid())
    name        String
    code        String? @unique
    description String?
    isDeleted   Boolean @default(false)

    // Relations
    products      Product[]
    subcategories Subcategory[]

    @@schema("tenant")
}

model Subcategory {
    id          String  @id @default(cuid())
    categoryId  String
    name        String
    description String?
    isDeleted   Boolean @default(false)

    // Relations
    category Category  @relation(fields: [categoryId], references: [id])
    products Product[]

    @@schema("tenant")
}

model Product {
    id            String   @id @default(cuid())
    name          String
    description   String?
    imageUrl      String?
    sku           String?  @unique
    barcode       String?  @unique
    price         Decimal? @default(0) @db.Decimal(10, 2)
    cost          Decimal? @default(0) @db.Decimal(10, 2)
    categoryId    String?
    subcategoryId String?
    isActive      Boolean  @default(true)
    isDeleted     Boolean  @default(false)
    isIngredient  Boolean  @default(false)
    isModifiable  Boolean  @default(false)
    createdAt     DateTime @default(now())
    taxId         String?

    // Relations
    tax              Tax?               @relation(fields: [taxId], references: [id])
    category         Category?          @relation(fields: [categoryId], references: [id])
    subcategory      Subcategory?       @relation(fields: [subcategoryId], references: [id])
    inventory        Inventory[]
    inventoryHistory InventoryHistory[]
    modifiers        Modifier[]
    recipesUsedIn    Recipe[]           @relation("SellableRecipe")
    ingredientIn     Recipe[]           @relation("IngredientRecipe")
    orderItems       OrderItem[]
    offerGroupItems  OfferGroupItem[]
    transferItems    TransferItem[]

    @@schema("tenant")
}

// =============================================================================
// CURRENCIES
// =============================================================================

model Currency {
    code         String   @id // e.g., USD, EUR, LBP
    name         String
    symbol       String?
    exchangeRate Decimal? @db.Decimal(10, 2)
    isActive     Boolean  @default(true)

    // Relations
    payments Payment[]

    @@schema("tenant")
}

// =============================================================================
// OFFERS & DISCOUNTS
// =============================================================================

model Offer {
    id        String  @id @default(cuid())
    name      String
    basePrice Decimal @default(0) @db.Decimal(10, 2)

    // Relations
    offerGroups OfferGroup[]

    @@schema("tenant")
}

model OfferGroup {
    id             String @id @default(cuid())
    offerId        String
    name           String
    freeItemsCount Int    @default(0)

    // Relations
    offer           Offer            @relation(fields: [offerId], references: [id])
    offerGroupItems OfferGroupItem[]

    @@schema("tenant")
}

model OfferGroupItem {
    id           String  @id @default(cuid())
    offerGroupId String
    productId    String
    extraPrice   Decimal @default(0) @db.Decimal(10, 2)

    // Relations
    offerGroup OfferGroup @relation(fields: [offerGroupId], references: [id])
    product    Product    @relation(fields: [productId], references: [id])

    @@unique([offerGroupId, productId])
    @@schema("tenant")
}

// =============================================================================
// INVENTORY
// =============================================================================
// Branch-scoped inventory (no tenantId needed - schema provides isolation)
// =============================================================================

model Inventory {
    id           String   @id @default(cuid())
    branchId     String
    productId    String
    stock        Decimal  @default(0) @db.Decimal(10, 4)
    minStock     Decimal  @default(0) @db.Decimal(10, 4)
    lastAdjusted DateTime @updatedAt

    // Relations
    branch  Branch  @relation(fields: [branchId], references: [id])
    product Product @relation(fields: [productId], references: [id])

    @@unique([branchId, productId])

    @@schema("tenant")
}

model InventoryHistory {
    id             String              @id @default(cuid())
    branchId       String
    productId      String
    userId         String
    changeType     InventoryChangeType
    beforeStock    Decimal             @db.Decimal(10, 4)
    afterStock     Decimal             @db.Decimal(10, 4)
    adjustment     Decimal             @db.Decimal(10, 4)
    beforeMinStock Decimal?            @db.Decimal(10, 4)
    afterMinStock  Decimal?            @db.Decimal(10, 4)
    reason         String?
    createdAt      DateTime            @default(now())

    // Relations
    branch  Branch  @relation(fields: [branchId], references: [id])
    product Product @relation(fields: [productId], references: [id])
    user    User    @relation(fields: [userId], references: [id])

    @@index([branchId, createdAt])
    @@index([productId, createdAt])
    @@index([userId, createdAt])

    @@schema("tenant")
}

// =============================================================================
// INVENTORY TRANSFERS
// =============================================================================

model Transfer {
    id           String         @id @default(cuid())
    fromBranchId String
    toBranchId   String
    status       TransferStatus @default(PENDING)
    requestedBy  String
    approvedBy   String?
    notes        String?
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    completedAt  DateTime?

    // Relations
    fromBranch Branch         @relation("TransfersFrom", fields: [fromBranchId], references: [id])
    toBranch   Branch         @relation("TransfersTo", fields: [toBranchId], references: [id])
    requestor  User           @relation("TransferRequests", fields: [requestedBy], references: [id])
    approver   User?          @relation("TransferApprovals", fields: [approvedBy], references: [id])
    items      TransferItem[]

    @@index([status])
    @@index([fromBranchId])
    @@index([toBranchId])

    @@schema("tenant")
}

model TransferItem {
    id         String  @id @default(cuid())
    transferId String
    productId  String
    quantity   Decimal @db.Decimal(10, 4)

    // Relations
    transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
    product  Product  @relation(fields: [productId], references: [id])

    @@unique([transferId, productId])

    @@schema("tenant")
}

// =============================================================================
// REFUNDS
// =============================================================================

model Refund {
    id          String   @id @default(cuid())
    orderId     String
    totalAmount Decimal  @default(0) @db.Decimal(10, 2)
    reason      String?
    refundedAt  DateTime @default(now())

    // Relations
    order       Order        @relation(fields: [orderId], references: [id])
    refundItems RefundItem[]

    @@schema("tenant")
}

model RefundItem {
    id          String  @id @default(cuid())
    refundId    String
    orderItemId String
    quantity    Decimal @db.Decimal(10, 4)
    unitPrice   Decimal @db.Decimal(10, 2)
    subtotal    Decimal @db.Decimal(10, 2)

    // Relations
    refund    Refund    @relation(fields: [refundId], references: [id])
    orderItem OrderItem @relation(fields: [orderItemId], references: [id])

    @@unique([refundId, orderItemId])
    @@index([orderItemId])

    @@schema("tenant")
}

// =============================================================================
// TABLES (Restaurant)
// =============================================================================

model Table {
    id          String  @id @default(cuid())
    tableNumber Int
    branchId    String
    name        String
    capacity    Int     @default(4)
    isActive    Boolean @default(true)
    isDeleted   Boolean @default(false)

    // Relations
    branch Branch  @relation(fields: [branchId], references: [id])
    orders Order[]

    @@schema("tenant")
}

// =============================================================================
// MODIFIERS (Toppings/Add-ons)
// =============================================================================

model ModifierGroup {
    id        String       @id @default(cuid())
    name      String
    type      ModifierType
    isDeleted Boolean      @default(false)

    // Relations
    modifiers Modifier[]

    @@schema("tenant")
}

model Modifier {
    id        String  @id @default(cuid())
    groupId   String
    productId String?
    name      String
    price     Decimal @default(0)
    isDeleted Boolean @default(false)

    // Relations
    group         ModifierGroup       @relation(fields: [groupId], references: [id])
    product       Product?            @relation(fields: [productId], references: [id])
    orderItemMods OrderItemModifier[]

    @@schema("tenant")
}

// =============================================================================
// RECIPES
// =============================================================================

model Recipe {
    id           String  @id @default(cuid())
    productId    String
    ingredientId String
    quantity     Decimal @db.Decimal(10, 4)

    // Relations
    product    Product @relation("SellableRecipe", fields: [productId], references: [id])
    ingredient Product @relation("IngredientRecipe", fields: [ingredientId], references: [id])

    @@unique([productId, ingredientId])
    @@schema("tenant")
}

// =============================================================================
// ORDERS
// =============================================================================

model Order {
    id          String      @id @default(cuid())
    userId      String?
    branchId    String
    tableId     String?
    deviceId    String?
    customerId  String?
    shiftId     String?
    orderNumber String?
    type        OrderType
    status      OrderStatus @default(DRAFT)
    subtotal    Decimal     @default(0) @db.Decimal(10, 2)
    taxAmount   Decimal     @default(0) @db.Decimal(10, 2)
    total       Decimal     @default(0) @db.Decimal(10, 2)
    discount    Decimal?    @default(0) @db.Decimal(10, 2)
    createdAt   DateTime    @default(now())
    completedAt DateTime?

    // Relations
    user     User?       @relation(fields: [userId], references: [id])
    branch   Branch      @relation(fields: [branchId], references: [id])
    table    Table?      @relation(fields: [tableId], references: [id])
    device   POSDevice?  @relation(fields: [deviceId], references: [id])
    customer Customer?   @relation(fields: [customerId], references: [id])
    shift    Shift?      @relation(fields: [shiftId], references: [id])
    items    OrderItem[]
    payments Payment[]
    refunds  Refund[]

    @@index([branchId, createdAt])
    @@index([status])
    @@schema("tenant")
}

// =============================================================================
// ORDER ITEMS
// =============================================================================

model OrderItem {
    id        String  @id @default(cuid())
    orderId   String
    productId String
    quantity  Decimal @default(1) @db.Decimal(10, 4)
    unitPrice Decimal @db.Decimal(10, 2)
    taxRate   Decimal @default(0) @db.Decimal(10, 2)
    taxAmount Decimal @default(0) @db.Decimal(10, 2)
    total     Decimal @db.Decimal(10, 2)
    notes     String?

    // Relations
    order       Order               @relation(fields: [orderId], references: [id])
    product     Product             @relation(fields: [productId], references: [id])
    modifiers   OrderItemModifier[]
    tickets     OrderItemTicket[]
    refundItems RefundItem[]

    @@schema("tenant")
}

model OrderItemTicket {
    id          String      @id @default(cuid())
    orderItemId String
    station     String?
    status      OrderStatus @default(SENT_TO_KITCHEN)
    sentAt      DateTime    @default(now())
    bumpedAt    DateTime?

    // Relations
    orderItem OrderItem @relation(fields: [orderItemId], references: [id])

    @@schema("tenant")
}

model OrderItemModifier {
    id          String  @id @default(cuid())
    orderItemId String
    modifierId  String
    price       Decimal @db.Decimal(10, 2)

    // Relations
    orderItem OrderItem @relation(fields: [orderItemId], references: [id])
    modifier  Modifier  @relation(fields: [modifierId], references: [id])

    @@schema("tenant")
}

// =============================================================================
// PAYMENTS
// =============================================================================

model Payment {
    id            String        @id @default(cuid())
    orderId       String
    method        PaymentMethod
    currencyCode  String        @default("USD")
    amount        Decimal
    exchangeRate  Decimal?
    transactionId String?
    paidAt        DateTime      @default(now())

    // Relations
    order    Order    @relation(fields: [orderId], references: [id])
    currency Currency @relation(fields: [currencyCode], references: [code])

    @@schema("tenant")
}

// =============================================================================
// CUSTOMERS
// =============================================================================

model Customer {
    id        String   @id @default(cuid())
    name      String
    email     String?
    phone     String?
    address   String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Relations
    orders Order[]

    @@schema("tenant")
}

// =============================================================================
// SHIFTS
// =============================================================================

model Shift {
    id         String      @id @default(cuid())
    branchId   String
    userId     String
    deviceId   String?
    startTime  DateTime    @default(now())
    endTime    DateTime?
    startCash  Decimal     @default(0) @db.Decimal(10, 2)
    endCash    Decimal?    @db.Decimal(10, 2)
    actualCash Decimal?    @db.Decimal(10, 2)
    difference Decimal?    @db.Decimal(10, 2)
    status     ShiftStatus @default(OPEN)
    notes      String?

    // Relations
    branch Branch     @relation(fields: [branchId], references: [id])
    user   User       @relation(fields: [userId], references: [id])
    device POSDevice? @relation(fields: [deviceId], references: [id])
    orders Order[]

    @@index([branchId, status])

    @@schema("tenant")
}

// =============================================================================
// TAXES
// =============================================================================

model Tax {
    id        String  @id @default(cuid())
    name      String
    rate      Decimal @db.Decimal(5, 2)
    isDefault Boolean @default(false)

    // Relations
    products Product[]

    @@schema("tenant")
}
