{
  "name": "offline-desktop",
  "productName": "CedarPoint POS Offline",
  "version": "0.1.0",
  "description": "Fully offline single-business desktop POS built on SQLite.",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "renderer:dev": "vite",
    "watch:main": "vite build --config vite.main.config.ts --watch",
    "watch:preload": "vite build --config vite.preload.config.ts --watch",
    "electron:dev": "cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5174 node scripts/dev-electron.cjs",
    "build:renderer": "vite build",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "dev": "npm-run-all --parallel build:main build:preload && npm-run-all --race --parallel renderer:dev watch:main watch:preload electron:dev",
    "package": "npm-run-all --parallel build:renderer build:main build:preload && electron-builder --config electron-builder.config.cjs --dir",
    "make": "npm-run-all --parallel build:renderer build:main build:preload && electron-builder --config electron-builder.config.cjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.54.2",
    "@hookform/resolvers": "^5.0.1",
    "recharts": "^3.6.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/router-plugin": "^1.143.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "cross-env": "^10.1.0",
    "electron": "39.8.10",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^2.1.8"
  }
}
