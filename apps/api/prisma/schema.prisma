generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ---------- TENANT (Multi-Tenancy Root) ----------
//
model Tenant {
  id               String       @id @default(uuid())
  name             String
  code             String?      @unique
  businessType     BusinessType
  baseCurrencyCode String       @default("USD") // Base currency for accounting/reporting
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  
  users                User[]
  branches             Branch[]
  products             Product[]
  inventory            Inventory[] // Inventory records still belong to the Tenant scope
  inventoryHistory     InventoryHistory[]
  orders               Order[]
  tables               Table[]
  floors               Floor[] // Restaurant floor layouts
  modifierGroups       ModifierGroup[]
  devices              POSDevice[]
  customers            Customer[]
  suppliers            Supplier[]
  purchaseOrders       PurchaseOrder[]
  shifts               Shift[]
  shiftSchedules       ShiftSchedule[]
  transfers            Transfer[]
  settings             Json? // feature flags, tax rates, etc.
  modifiers            Modifier[]
  categories           Category[]
  tenantCurrencies     TenantCurrency[] // Tenant-specific currency configurations
  colors               Color[]
  loyaltyProgram       LoyaltyProgram?
  loyaltyAccounts      LoyaltyAccount[]
  loyaltyTransactions  LoyaltyTransaction[]
  offers               Offer[]
  refunds              Refund[]
  cashMovements        CashMovement[]
  orderSequences       OrderSequence[]
  activityLogs         StaffActivityLog[]
  staffSessions        StaffSession[]
  reservations         Reservation[]
  reservationSequences ReservationSequence[]
  orderCustomers      OrderCustomer[]
}

model Currency {
  code             String           @id
  name             String
  symbol           String?
  decimalPlaces    Int              @default(2)
  payments         Payment[]
  tenantCurrencies TenantCurrency[]
}

model TenantCurrency {
  id           String   @id @default(uuid())
  tenantId     String
  currencyCode String
  exchangeRate Decimal  @db.Decimal(18, 6)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  currency     Currency @relation(fields: [currencyCode], references: [code])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // "One base currency per tenant" is enforced by a partial unique index:
  // CREATE UNIQUE INDEX one_base_currency_per_tenant ON "TenantCurrency"
  // ("tenantId") WHERE ("isDefault" = true).
  // Prisma's @@unique can't express a partial index. A full @@unique on
  // (tenantId, isDefault) is WRONG: it also caps a tenant at one non-default
  // currency and breaks setBaseCurrency's reset-all-to-false swap.
  @@unique([tenantId, currencyCode])
  @@index([tenantId, isActive])
}

model User {
  id    String  @id @default(uuid())
  name  String
  email String? @unique
  phone String? @unique

  username            String
  password            String
  pinHash             String? // bcrypt-hashed 4-6 digit PIN for POS login
  hasPosAccess        Boolean              @default(true) // POS register access, separate from isActive
  branchId            String? // default branch assignment
  lastLoginAt         DateTime?
  avatar              String?
  role                UserRole             @default(CASHIER)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenantId            String?
  refreshToken        String?
  inventoryHistory    InventoryHistory[]
  orders              Order[]
  shifts              Shift[]
  transfersApproved   Transfer[]           @relation("TransferApprovals")
  transfersRequested  Transfer[]           @relation("TransferRequests")
  loyaltyTransactions LoyaltyTransaction[] @relation("UserLoyaltyTransactions")
  payments            Payment[]
  shiftsClosedBy      Shift[]              @relation("ShiftClosedBy")
  shiftsApprovedBy    Shift[]              @relation("ShiftApprovedBy")
  cashMovements       CashMovement[]
  shiftSchedules      ShiftSchedule[]
  schedulesPublished  ShiftSchedule[]      @relation("SchedulePublishedBy")
  activityLogs        StaffActivityLog[]
  staffSessions       StaffSession[]
  createdReservations Reservation[]        @relation("ReservationCreatedBy")
  branch              Branch?              @relation("UserBranch", fields: [branchId], references: [id], onDelete: SetNull)
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, role])
  @@unique([tenantId, username])
  @@index([tenantId, role])
  @@index([tenantId, branchId])
}

model Branch {
  id                   String                @id @default(uuid())
  tenantId             String
  name                 String
  address              String?
  phone                String?
  isDeleted            Boolean               @default(false) // Soft delete
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables               Table[]
  floors               Floor[] // Restaurant floor layouts
  devices              POSDevice[]
  inventory            Inventory[] // Inventory is tracked at the Branch level
  orders               Order[]
  shifts               Shift[]
  shiftSchedules       ShiftSchedule[]
  inventoryHistory     InventoryHistory[]
  transfersFrom        Transfer[]            @relation("TransfersFrom")
  transfersTo          Transfer[]            @relation("TransfersTo")
  products             Product[]
  purchaseOrders       PurchaseOrder[]
  refunds              Refund[]
  cashMovements        CashMovement[]
  orderSequences       OrderSequence[]
  staffSessions        StaffSession[]
  staffMembers         User[]                @relation("UserBranch")
  reservations         Reservation[]
  reservationSequences ReservationSequence[]
}

model POSDevice {
  id             String          @id @default(uuid())
  tenantId       String
  branchId       String
  name           String
  token          String          @unique
  lastSync       DateTime?
  isActive       Boolean         @default(true)
  isKDS          Boolean         @default(false)
  orders         Order[]
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts         Shift[]
  shiftSchedules ShiftSchedule[]
  payments       Payment[]
  cashMovements  CashMovement[]
}

model Category {
  id            String        @id @default(uuid())
  tenantId      String
  name          String
  code          String?       @unique
  description   String?
  deletedAt     DateTime?
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products      Product[]
  subcategories Subcategory[]
  colorId       String?
  color         Color?        @relation(fields: [colorId], references: [id])
}

model Color {
  id         String     @id @default(uuid())
  name       String
  hex        String
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categories Category[]

  @@unique([tenantId, hex])
  @@unique([tenantId, name])
}

model Subcategory {
  id          String    @id @default(uuid())
  categoryId  String
  name        String
  description String?
  deletedAt   DateTime?
  products    Product[]
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String                      @id @default(uuid())
  tenantId            String
  name                String
  description         String?
  imageUrl            String?
  imageKey            String? // storage object key; imageUrl is derived from this for B2-backed media
  sku                 String?                     @unique
  barcode             String?                     @unique
  price               Decimal?                    @default(0) @db.Decimal(10, 2)
  cost                Decimal?                    @default(0) @db.Decimal(10, 2)
  categoryId          String?
  subcategoryId       String?
  isActive            Boolean                     @default(true)
  deletedAt           DateTime?
  isModifiable        Boolean                     @default(false)
  createdAt           DateTime                    @default(now())
  branchId            String?
  inventory           Inventory[]
  inventoryHistory    InventoryHistory[]
  modifiers           Modifier[]
  modifierAssignments ModifierProductAssignment[]
  offerGroupItems     OfferGroupItem[]
  orderItems          OrderItem[]
  branch              Branch?                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category            Category?                   @relation(fields: [categoryId], references: [id])
  subcategory         Subcategory?                @relation(fields: [subcategoryId], references: [id])
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  RefundItem          RefundItem[]
  transferItems       TransferItem[]
  purchaseOrderItems  PurchaseOrderItem[]
}

model Offer {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  basePrice   Decimal      @default(0) @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  offerGroups OfferGroup[]

  @@index([tenantId])
}

model OfferGroup {
  id              String           @id @default(uuid())
  offerId         String
  name            String
  freeItemsCount  Int              @default(0)
  maxItemsCount   Int              @default(1)
  offer           Offer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerGroupItems OfferGroupItem[]

  @@index([offerId])
}

model OfferGroupItem {
  id           String     @id @default(uuid())
  offerGroupId String
  productId    String
  extraPrice   Decimal    @default(0) @db.Decimal(10, 2)
  offerGroup   OfferGroup @relation(fields: [offerGroupId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])

  @@unique([offerGroupId, productId])
}

model Inventory {
  id           String   @id @default(uuid())
  tenantId     String
  branchId     String
  productId    String
  stock        Decimal  @default(0) @db.Decimal(10, 4)
  minStock     Decimal  @default(0) @db.Decimal(10, 4)
  lastAdjusted DateTime @updatedAt
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
}

model InventoryHistory {
  id             String              @id @default(uuid())
  tenantId       String
  branchId       String
  productId      String
  userId         String
  changeType     InventoryChangeType
  beforeStock    Decimal             @db.Decimal(10, 4)
  afterStock     Decimal             @db.Decimal(10, 4)
  adjustment     Decimal             @db.Decimal(10, 4)
  beforeMinStock Decimal?            @db.Decimal(10, 4)
  afterMinStock  Decimal?            @db.Decimal(10, 4)
  reason         String?
  createdAt      DateTime            @default(now())
  referenceId    String?
  referenceType  String?
  branch         Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([referenceId, referenceType])
}

model Transfer {
  id           String         @id @default(uuid())
  tenantId     String
  fromBranchId String
  toBranchId   String
  status       TransferStatus @default(PENDING)
  requestedBy  String
  approvedBy   String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  completedAt  DateTime?
  approver     User?          @relation("TransferApprovals", fields: [approvedBy], references: [id])
  fromBranch   Branch         @relation("TransfersFrom", fields: [fromBranchId], references: [id], onDelete: Cascade)
  requestor    User           @relation("TransferRequests", fields: [requestedBy], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  toBranch     Branch         @relation("TransfersTo", fields: [toBranchId], references: [id], onDelete: Cascade)
  items        TransferItem[]

  @@index([tenantId, status])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model TransferItem {
  id         String   @id @default(uuid())
  transferId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 4)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@unique([transferId, productId])
}

model Refund {
  id                    String   @id @default(uuid())
  orderId               String?
  totalAmount           Decimal  @default(0) @db.Decimal(10, 2)
  reason                String?
  refundedAt            DateTime @default(now())
  manualRefund          Boolean  @default(false)
  paymentMethod         String?
  loyaltyPointsRestored Int      @default(0)
  loyaltyPointsReversed Int      @default(0)

  // Shift attribution (optional for backward compatibility)
  tenantId       String?
  branchId       String?
  shiftId        String?
  deviceId       String?
  userId         String?
  idempotencyKey String?

  order               Order?               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refundItems         RefundItem[]
  refundPayments      RefundPayment[]
  loyaltyTransactions LoyaltyTransaction[] @relation("RefundLoyaltyTransactions")
  shift               Shift?               @relation(fields: [shiftId], references: [id])
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([shiftId])
  @@index([tenantId, refundedAt])
}

model RefundItem {
  id          String     @id @default(uuid())
  refundId    String
  orderItemId String?
  quantity    Decimal    @db.Decimal(10, 4)
  unitPrice   Decimal    @db.Decimal(10, 2)
  subtotal    Decimal    @db.Decimal(10, 2)
  productId   String?
  productName String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  Product     Product?   @relation(fields: [productId], references: [id])
  refund      Refund     @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([productId])
  @@index([refundId])
}

model RefundPayment {
  id           String        @id @default(uuid())
  refundId     String
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  currencyCode String?
  exchangeRate Decimal?      @db.Decimal(18, 6)

  // Attribution
  shiftId  String?
  deviceId String?
  userId   String?

  createdAt DateTime @default(now())

  refund Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)
  shift  Shift? @relation(fields: [shiftId], references: [id])

  @@index([refundId])
  @@index([shiftId])
}

//
// ---------- CASH MOVEMENT LEDGER ----------
//
model CashMovement {
  id             String                     @id @default(uuid())
  tenantId       String
  branchId       String
  shiftId        String
  deviceId       String?
  userId         String
  type           CashMovementType
  amount         Decimal                    @db.Decimal(10, 2)
  reason         String?
  referenceId    String? // orderId, refundId, or paymentId
  referenceType  CashMovementReferenceType? // Normalized reference type
  idempotencyKey String?
  createdAt      DateTime                   @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift  Shift      @relation(fields: [shiftId], references: [id])
  device POSDevice? @relation(fields: [deviceId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([shiftId, type])
  @@index([tenantId, branchId, createdAt])
  @@index([referenceId, referenceType])
}

//
// ---------- RESTAURANT MODULE (FLOORS & TABLES) ----------
//
model Floor {
  id        String    @id @default(uuid())
  tenantId  String
  branchId  String
  name      String
  order     Int       @default(0) // For UI ordering
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables Table[]

  @@index([branchId, deletedAt])
}

model Table {
  id          String      @id @default(uuid())
  tableNumber Int
  tenantId    String
  branchId    String
  floorId     String? // Optional floor assignment
  name        String
  capacity    Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  posX        Int
  posY        Int
  width       Int
  height      Int
  rotation    Int
  shape       TableShape?
  isActive    Boolean     @default(true)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  floor        Floor?        @relation(fields: [floorId], references: [id], onDelete: SetNull)
  orders       Order[]
  reservations Reservation[]

  @@index([branchId, deletedAt])
  @@index([floorId])
}

model ModifierGroup {
  id        String       @id @default(uuid())
  tenantId  String
  name      String
  type      ModifierType
  deletedAt DateTime?
  modifiers Modifier[]
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Modifier {
  id                 String                      @id @default(uuid())
  tenantId           String
  groupId            String
  productId          String? // @deprecated - kept for backward compatibility
  name               String
  price              Decimal                     @default(0)
  deletedAt          DateTime?
  group              ModifierGroup               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product            Product?                    @relation(fields: [productId], references: [id])
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItemMods      OrderItemModifier[]
  productAssignments ModifierProductAssignment[]
}

model ModifierProductAssignment {
  id         String   @id @default(uuid())
  modifierId String
  productId  String
  createdAt  DateTime @default(now())

  modifier Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([modifierId, productId])
  @@index([modifierId])
  @@index([productId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  from      OrderStatus
  to        OrderStatus
  userId    String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Order {
  id          String    @id @default(uuid())
  tenantId    String
  userId      String?
  branchId    String
  tableId     String?
  deviceId    String?
  customerId  String?
  shiftId     String?
  orderNumber String?
  type        OrderType
  guestCount  Int? // Number of guests for dine-in orders

  status                          OrderStatus          @default(DRAFT)
  paymentStatus                   PaymentStatus        @default(UNPAID)
  subtotal                        Decimal              @default(0) @db.Decimal(10, 2)
  total                           Decimal              @default(0) @db.Decimal(10, 2)
  discount                        Decimal?             @default(0) @db.Decimal(10, 2)
  createdAt                       DateTime             @default(now())
  placedAt                        DateTime?
  servedAt                        DateTime?
  completedAt                     DateTime?
  shippingFee                     Decimal?             @default(0) @db.Decimal(10, 2)
  currencyCode                    String?              @default("USD")
  exchangeRate                    Decimal?             @db.Decimal(18, 6)
  includeVAT                      Boolean              @default(false)
  vat                             Decimal?             @default(0) @db.Decimal(10, 2)
  loyaltyRedeemedPoints           Int                  @default(0)
  loyaltyRedeemedAmount           Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyEarnedPoints             Int                  @default(0)
  loyaltyEligibleBaseAtCompletion Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyRedeemBaseAtCompletion   Decimal              @default(0) @db.Decimal(10, 2)
  loyaltyProgramSnapshot          Json?
  loyaltyCompletedAt              DateTime?
  idempotencyKey                  String?
  branch                          Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer                        Customer?            @relation(fields: [customerId], references: [id])
  device                          POSDevice?           @relation(fields: [deviceId], references: [id])
  shift                           Shift?               @relation(fields: [shiftId], references: [id])
  table                           Table?               @relation(fields: [tableId], references: [id])
  tenant                          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                            User?                @relation(fields: [userId], references: [id])
  items                           OrderItem[]
  payments                        Payment[]
  refunds                         Refund[]
  loyaltyTransactions             LoyaltyTransaction[] @relation("OrderLoyaltyTransactions")
  statusHistory                   OrderStatusHistory[]
  reservation                     Reservation?
  orderCustomers                  OrderCustomer[]

  @@unique([branchId, orderNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, paymentStatus])
}

model OrderItem {
  id          String              @id @default(uuid())
  orderId     String
  productId   String
  quantity    Decimal             @default(1) @db.Decimal(10, 4)
  unitPrice   Decimal             @db.Decimal(10, 2)
  subtotal    Decimal             @default(0) @db.Decimal(10, 2)
  total       Decimal             @db.Decimal(10, 2)
  notes       String?
  discount    Json?
  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifiers   OrderItemModifier[]
  tickets     OrderItemTicket[]
  refundItems RefundItem[]
}

model OrderItemTicket {
  id          String       @id @default(uuid())
  orderItemId String
  station     String?
  status      TicketStatus @default(QUEUED)
  sentAt      DateTime     @default(now())
  bumpedAt    DateTime?
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model OrderItemModifier {
  id          String    @id @default(uuid())
  orderItemId String
  modifierId  String
  price       Decimal   @db.Decimal(10, 2)
  modifier    Modifier  @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String
  method        PaymentMethod
  currencyCode  String?
  amount        Decimal
  exchangeRate  Decimal?
  transactionId String?
  paidAt        DateTime      @default(now())

  // Shift attribution (optional for backward compatibility)
  shiftId        String?
  deviceId       String?
  userId         String?
  idempotencyKey String?

  currency Currency?  @relation(fields: [currencyCode], references: [code])
  order    Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shift    Shift?     @relation(fields: [shiftId], references: [id])
  device   POSDevice? @relation(fields: [deviceId], references: [id])
  user     User?      @relation(fields: [userId], references: [id])

  @@unique([orderId, idempotencyKey])
  @@index([shiftId])
  @@index([orderId])
}

model Customer {
  id                  String               @id @default(uuid())
  tenantId            String
  name                String
  email               String?
  phone               String?
  address             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders              Order[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  reservations        Reservation[]
  orderCustomers      OrderCustomer[]

  @@index([tenantId])
}

/// Join table linking an Order to one or more Customers (shared bill).
/// The primary customer (isPrimary) is mirrored on Order.customerId and is the
/// one that earns/redeems loyalty; the others are linked for shared history.
model OrderCustomer {
  id         String   @id @default(uuid())
  tenantId   String
  orderId    String
  customerId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([orderId, customerId])
  @@index([customerId])
  @@index([tenantId])
}

model LoyaltyProgram {
  id                     String                @id @default(uuid())
  tenantId               String                @unique
  isEnabled              Boolean               @default(false)
  enrollmentMode         LoyaltyEnrollmentMode @default(AUTO)
  earnPointsPerCurrency  Decimal?              @db.Decimal(10, 4)
  redeemPointsStep       Int?
  redeemCurrencyPerStep  Decimal?              @db.Decimal(10, 2)
  minRedeemPoints        Int                   @default(0)
  maxRedeemPercent       Decimal?              @db.Decimal(5, 2)
  allowNoCustomerAccrual Boolean               @default(false)
  pointsExpirationDays   Int?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isEnabled])
}

model LoyaltyAccount {
  id               String               @id @default(uuid())
  tenantId         String
  customerId       String               @unique
  pointsBalance    Int                  @default(0)
  lifetimeEarned   Int                  @default(0)
  lifetimeRedeemed Int                  @default(0)
  lifetimeRestored Int                  @default(0)
  lifetimeReversed Int                  @default(0)
  lifetimeAdjusted Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions     LoyaltyTransaction[]

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, pointsBalance])
}

model LoyaltyTransaction {
  id             String                 @id @default(uuid())
  tenantId       String
  accountId      String
  customerId     String
  orderId        String?
  refundId       String?
  type           LoyaltyTransactionType
  direction      LoyaltyDirection
  points         Int
  moneyAmount    Decimal?               @db.Decimal(10, 2)
  balanceAfter   Int
  idempotencyKey String                 @unique
  reason         String?
  metadata       Json?
  actorUserId    String?
  createdAt      DateTime               @default(now())
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account        LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer       Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order          Order?                 @relation("OrderLoyaltyTransactions", fields: [orderId], references: [id], onDelete: SetNull)
  refund         Refund?                @relation("RefundLoyaltyTransactions", fields: [refundId], references: [id], onDelete: SetNull)
  actorUser      User?                  @relation("UserLoyaltyTransactions", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([accountId, createdAt])
  @@index([orderId])
  @@index([refundId])
}

//
// ---------- SUPPLIER MODULE ----------
